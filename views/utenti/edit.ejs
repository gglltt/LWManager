<%- include("../partials/header") %>

<section class="card">
  <div class="pageHeader">
    <div>
      <h1><%= t("edit_user") %></h1>
      <p class="muted"><%= t("email_not_editable") %></p>
    </div>
    <div class="pageHeaderActions">
      <a class="button secondary" href="/utenti">← <%= t("users") %></a>
    </div>
  </div>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form method="POST" action="/utenti/<%= target._id %>/edit" class="form">
    <label><%= t("email_not_editable_long") %></label>
    <input type="text" value="<%= target.email %>" disabled />

    <label>Nickname</label>
    <input type="text" name="nickname" required minlength="2" maxlength="40" value="<%= target.nickname || '' %>" />

    <label><%= t("level_label") %></label>
    <select name="authLevel" required>
      <% for (let i = 1; i <= 5; i++) { %>
        <option value="<%= i %>" <%= (Number(target.authLevel) === i ? 'selected' : '') %>><%= i %></option>
      <% } %>
    </select>

    <button type="submit"><%= t("save") %></button>
  </form>
</section>

<%- include("../partials/footer") %>
