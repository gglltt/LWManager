<%- include("../partials/header") %>

<%
  function fmtDate(d) {
    if (!d) return "-";
    const dt = new Date(d);
    if (Number.isNaN(dt.getTime())) return "-";
    return dt.toLocaleString(localeTag);
  }
%>

<section class="card cardWide">
  <div class="pageHeader">
    <div>
      <h1><%= t("users_management") %></h1>
      <p class="muted"><%= t("users_admin_note") %></p>
    </div>
    <div class="pageHeaderActions">
      <a class="button secondary" href="/dashboard">← <%= t("back_dashboard") %></a>
    </div>
  </div>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <div class="tableWrap">
    <table class="table tableCompact">
      <thead>
        <tr>
          <th class="colUEmail">Email</th>
          <th class="colUNick">Nickname</th>
          <th class="colULevel"><%= t("level_short") %></th>
          <th class="colUVer"><%= t("verified_short") %></th>
          <th class="colUDate"><%= t("updated_short") %></th>
          <th class="colActions"><%= t("actions_short") %></th>
        </tr>
      </thead>
      <tbody>
        <% if (!users || users.length === 0) { %>
          <tr><td colspan="6" class="muted"><%= t("no_users") %></td></tr>
        <% } %>

        <% users.forEach(u => { %>
          <tr>
            <td class="colUEmail" title="<%= u.email %>"><%= u.email %></td>
            <td class="colUNick" title="<%= u.nickname %>"><%= u.nickname %></td>
            <td class="colULevel"><b><%= u.authLevel %></b></td>
            <td class="colUVer"><%= u.verified ? "✅" : "❌" %></td>
            <td class="colUDate" title="<%= fmtDate(u.updatedAt) %>"><%= fmtDate(u.updatedAt) %></td>
            <td class="colActions">
              <div class="actionIcons">
                <a class="iconBtn" href="/utenti/<%= u._id %>/edit" title="<%= t('edit') %>">✏️</a>

                <% const selfId = String(user?._id || user?.id || ""); %>
                <% if (String(u._id) !== selfId) { %>
                  <form method="POST" action="/utenti/<%= u._id %>/delete" class="inlineForm"
                        onsubmit="return confirm('<%= t(&apos;confirm_delete_player&apos;) %> <%= u.email %>?');">
                    <button class="iconBtn danger" type="submit" title="<%= t('delete') %>">🗑️</button>
                  </form>
                <% } else { %>
                  <span class="muted" title="<%= t(&apos;cannot_delete_self&apos;) %>">—</span>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include("../partials/footer") %>
