<!doctype html>
<html lang="<%= currentLang || 'it' %>" dir="<%= isRTL ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== "undefined" ? `${title} · LWManager` : "LWManager" %></title>
  <link rel="stylesheet" href="/styles.css" />
  <% if (typeof extraCss !== "undefined" && Array.isArray(extraCss)) { %>
    <% extraCss.forEach((href) => { %>
      <link rel="stylesheet" href="<%= href %>" />
    <% }) %>
  <% } %>
</head>
<%
  const isAuthenticated = typeof user !== "undefined" && Boolean(user);
  const requestPath = String(typeof currentUrl !== "undefined" ? currentUrl : "").split("?")[0];
  const isLoginPage = requestPath === "/auth/login" || requestPath === "/login";
%>
<body class="<%= isLoginPage ? 'login-page' : '' %>">
  <div id="lwmanager-splash" class="splash" role="status" aria-live="polite" aria-label="<%= t('splash_label') %>" hidden>
    <div class="splash__scanline" aria-hidden="true"></div>
    <div class="splash__panel">
      <div class="splash__logoWrap">
        <img class="splash__logo" src="/images/biss/biss-logo.svg" alt="<%= t('biss_logo_alt') %>" />
        <span class="splash__logoFallback"><%= t('brand_biss') %></span>
      </div>
      <p class="splash__eyebrow">LWManager</p>
      <h1 class="splash__title">Biss</h1>
      <p class="splash__subtitle"><%= t('made_in_italy') %></p>
    </div>
  </div>
  <header class="topbar <%= isLoginPage ? 'topbar--login' : '' %>">
    <div class="container topbar__inner">
      <div class="brand">LWManager</div>
      <div class="topbarRight">
        <% if (isAuthenticated) { %>
          <a class="headerHome btn-icon" href="/dashboard" aria-label="Home" title="Home">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M3.5 10.5 12 3.75l8.5 6.75"></path>
              <path d="M5.5 9.25v10h13v-10M9.5 19.25v-6h5v6"></path>
            </svg>
          </a>
        <% } %>

        <a class="headerContact" href="mailto:info@bisslastwar.com" aria-label="<%= t('contact_us') %>" title="<%= t('contact_us') %>">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <rect x="3" y="5" width="18" height="14" rx="2.5"></rect>
            <path d="m4.5 7 7.5 6 7.5-6"></path>
          </svg>
          <span><%= t('contact_us') %></span>
        </a>

        <% if (isAuthenticated || !isLoginPage) { %>
          <div class="mainMenu" data-main-menu>
            <button
              class="mainMenu__toggle btn-icon"
              type="button"
              aria-label="Apri menu"
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls="mainMenuDropdown">
              <span class="mainMenu__icon" aria-hidden="true">☰</span>
            </button>
            <nav id="mainMenuDropdown" class="mainMenu__dropdown" aria-label="<%= t('menu') %>" hidden>
              <% if (isAuthenticated) { %>
                <a href="/potenze"><%= t('nav_powers') %></a>
                <a href="/minigiochi"><%= t('minigames.menu') %></a>
                <% if (typeof user !== "undefined" && user && (user.isMaster || user.role === 'supervisor')) { %><a href="/passwords"><%= t('password_management') %></a><% } %>
                <% if (typeof user !== "undefined" && user && user.isMaster) { %><a href="/admin"><%= t('admin_title') %></a><% } %>
                <a class="mainMenu__logout" href="/logout"><%= t('nav_logout') %></a>
              <% } else if (!isLoginPage) { %>
                <a href="/auth/login"><%= t('nav_login') %></a>
              <% } %>
            </nav>
          </div>
        <% } %>

        <details class="langPicker">
          <summary class="langPicker__summary" aria-label="<%= t('lang_selector') %>">
            <span class="langPicker__flag"><%= currentFlag %></span>
          </summary>
          <div class="langPicker__menu">
            <% (availableLanguages || []).forEach(item => { %>
              <% if (!item.active) { %>
                <a
                  class="langPicker__item"
                  href="/set-language?lang=<%= encodeURIComponent(item.code) %>&returnTo=<%= encodeURIComponent(currentUrl || '/') %>">
                  <span class="langPicker__itemFlag"><%= item.flag %></span>
                  <span><%= item.name %></span>
                </a>
              <% } %>
            <% }) %>
          </div>
        </details>
      </div>
    </div>
  </header>
  <main class="container <%= isLoginPage ? 'login-shell' : '' %>">
