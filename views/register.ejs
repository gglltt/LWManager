<%- include("partials/header") %>

<section class="card">
  <h1><%= t('register_title') %></h1>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form method="POST" action="/auth/register" class="form">
    <label>Email</label>
    <input type="email" name="email" required placeholder="name@domain.com" />

    <label><%= t('nickname') %></label>
    <input type="text" name="nickname" required minlength="2" maxlength="40" placeholder="<%= t('your_nickname') %>" />

    <label><%= t('password_min8') %></label>
    <input type="password" name="password" required minlength="8" placeholder="********" />

    <button type="submit"><%= t('create_account') %></button>
  </form>

  <p class="muted">
    <%= t('already_account') %> <a href="/auth/login"><%= t('nav_login') %></a>
  </p>
</section>

<%- include("partials/footer") %>
