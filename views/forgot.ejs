<%- include("partials/header") %>

<section class="card">
  <h1><%= t('forgot_title') %></h1>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form method="POST" action="/auth/forgot" class="form">
    <label>Email</label>
    <input type="email" name="email" required placeholder="name@domain.com" />
    <button type="submit"><%= t('send_reset_link') %></button>
  </form>

  <p class="muted"><a href="/auth/login"><%= t('back_to_login') %></a></p>
</section>

<%- include("partials/footer") %>
