<%- include("partials/header") %>

<section class="card">
  <h1>Dashboard Biss</h1>

  <div class="kv">
    <div><b>Modalità accesso:</b> <%= user && user.authLevel >= 5 ? "Amministratore" : "Standard" %></div>
  </div>

  <hr class="divider" />

  <h2 class="sectionTitle">Menu</h2>

  <div class="menuGrid">
    <a class="menuCard" href="/potenze" title="Gestione Potenze">
      <div class="menuIcon">⚡</div>
      <div class="menuText">
        <div class="menuTitle">Potenze</div>
        <div class="menuDesc">Lista giocatori, potenze e tipi (T1–T4)</div>
      </div>
    </a>

    <a class="menuCard" href="/registro" title="Registro Eventi">
      <div class="menuIcon">📘</div>
      <div class="menuText">
        <div class="menuTitle">Registro</div>
        <div class="menuDesc">Log attività (login e operazioni sui player)</div>
      </div>
    </a>
  </div>

  <div style="margin-top: 16px;">
    <a class="button" href="/logout">Logout</a>
  </div>
</section>

<%- include("partials/footer") %>
