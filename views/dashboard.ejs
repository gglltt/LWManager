<%- include("partials/header") %>

<section class="card">
  <h1><%= t('dashboard_title_named').replace('{alliance}', allianceName || t('unknown')) %></h1>

  <div class="kv">
    <div><b><%= t('access_mode') %>:</b> <%= user && user.isMaster ? t('admin') : (user && user.authLevel >= 3 ? t('supervisor') : t('standard')) %></div>
  </div>

  <hr class="divider" />

  <h2 class="sectionTitle"><%= t('menu') %></h2>

  <div class="menuGrid">
    <a class="menuCard" href="/potenze" title="<%= t('nav_powers') %>">
      <div class="menuIcon">⚡</div>
      <div class="menuText">
        <div class="menuTitle"><%= t('nav_powers') %></div>
        <div class="menuDesc"><%= t('powers_desc') %></div>
      </div>
    </a>


    <a class="menuCard" href="/math-game" title="<%= t('mathGame.menu') %>">
      <div class="menuIcon">🧮</div>
      <div class="menuText">
        <div class="menuTitle"><%= t('mathGame.menu') %></div>
        <div class="menuDesc"><%= t('mathGame.dashboardDesc') %></div>
      </div>
    </a>

    <% if (user && /^it/i.test(String(currentLang || ''))) { %>
      <a class="menuCard" href="/word-game" title="<%= t('wordGame.dashboardTitle') %>">
        <div class="menuIcon">🔤</div>
        <div class="menuText">
          <div class="menuTitle"><%= t('wordGame.dashboardTitle') %></div>
          <div class="menuDesc"><%= t('wordGame.dashboardDesc') %></div>
        </div>
      </a>
    <% } %>


    <a class="menuCard" href="/stagione-6" title="<%= t('season6_guide_short') %>">
      <div class="menuIcon">🧭</div>
      <div class="menuText">
        <div class="menuTitle"><%= t('season6_guide_short') %></div>
        <div class="menuDesc"><%= t('season6_dashboard_desc') %></div>
      </div>
    </a>


    <% if (user && (user.isMaster || user.role === 'supervisor')) { %>
      <a class="menuCard" href="/passwords" title="<%= t('password_management') %>">
        <div class="menuIcon">🔐</div>
        <div class="menuText">
          <div class="menuTitle"><%= t('password_management') %></div>
          <div class="menuDesc"><%= user.isMaster ? t('password_management_master_desc') : t('password_management_supervisor_desc') %></div>
        </div>
      </a>
    <% } %>

    <% if (user && user.authLevel >= 3) { %>
      <a class="menuCard" href="/performance-vs" title="<%= t('perf_title') %>">
        <div class="menuIcon">🏆</div>
        <div class="menuText">
          <div class="menuTitle"><%= t('perf_title') %></div>
          <div class="menuDesc"><%= t('perf_desc') %></div>
        </div>
      </a>
    <% } %>

    <% if (user && user.isMaster) { %>
      <a class="menuCard" href="/admin" title="<%= t('admin_title') %>">
        <div class="menuIcon">🛡️</div>
        <div class="menuText">
          <div class="menuTitle"><%= t('admin_title') %></div>
          <div class="menuDesc"><%= t('admin_desc') %></div>
        </div>
      </a>
    <% } %>
  </div>

  <div style="margin-top: 16px;">
    <a class="button" href="/logout"><%= t('nav_logout') %></a>
  </div>
</section>

<%- include("partials/footer") %>
