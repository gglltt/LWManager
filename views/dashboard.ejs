<%- include("partials/header") %>

<section class="card">
  <h1><%= t('dashboard_title') %></h1>

  <div class="kv">
    <div><b><%= t('access_mode') %>:</b> <%= user && user.authLevel >= 5 ? t('admin') : (user && user.authLevel >= 3 ? t('supervisor') : t('standard')) %></div>
  </div>

  <hr class="divider" />

  <h2 class="sectionTitle"><%= t('menu') %></h2>

  <div class="menuGrid">
    <a class="menuCard" href="/potenze" title="<%= t('nav_powers') %>">
      <div class="menuIcon">⚡</div>
      <div class="menuText">
        <div class="menuTitle"><%= t('nav_powers') %></div>
        <div class="menuDesc"><%= t('powers_desc') %></div>
      </div>
    </a>

    <a class="menuCard" href="/novita" title="<%= t('nav_news') %>">
      <div class="menuIcon">🆕</div>
      <div class="menuText">
        <div class="menuTitle"><%= t('nav_news') %></div>
        <div class="menuDesc"><%= t('news_desc') %></div>
      </div>
    </a>

    <a class="menuCard" href="/stagione-6" title="Guida S6">
      <div class="menuIcon">🧭</div>
      <div class="menuText">
        <div class="menuTitle">Guida S6</div>
        <div class="menuDesc">Priorità, edifici, War Merit, pesca e calendario iniziale</div>
      </div>
    </a>

    <% if (user && user.isMaster) { %>
      <a class="menuCard" href="/season6-strategy" title="Strategia S6">
        <div class="menuIcon">🗺️</div>
        <div class="menuText">
          <div class="menuTitle">Strategia S6</div>
          <div class="menuDesc">Mappa, fronti, alleati, altari e piano operativo 4v4</div>
        </div>
      </a>
    <% } %>

    <% if (user && (user.isMaster || user.role === 'supervisor')) { %>
      <a class="menuCard" href="/passwords" title="Gestione PIN">
        <div class="menuIcon">🔐</div>
        <div class="menuText">
          <div class="menuTitle">Gestione PIN</div>
          <div class="menuDesc"><%= user.isMaster ? 'Reset PIN standard e supervisori di tutte le alleanze' : 'Modifica PIN standard e supervisore della tua alleanza' %></div>
        </div>
      </a>
    <% } %>

    <% if (user && user.authLevel >= 3) { %>
      <a class="menuCard" href="/performance-vs" title="<%= t('perf_title') %>">
        <div class="menuIcon">🏆</div>
        <div class="menuText">
          <div class="menuTitle"><%= t('perf_title') %></div>
          <div class="menuDesc"><%= t('perf_desc') %></div>
        </div>
      </a>
    <% } %>

    <% if (user && user.authLevel >= 5) { %>
      <a class="menuCard" href="/admin" title="<%= t('admin_title') %>">
        <div class="menuIcon">🛡️</div>
        <div class="menuText">
          <div class="menuTitle"><%= t('admin_title') %></div>
          <div class="menuDesc"><%= t('admin_desc') %></div>
        </div>
      </a>
    <% } %>
  </div>

  <div style="margin-top: 16px;">
    <a class="button" href="/logout"><%= t('nav_logout') %></a>
  </div>
</section>

<%- include("partials/footer") %>
