<%- include("partials/header") %>

<section class="card">
  <h1><%= t('reset_title') %></h1>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form method="POST" action="/auth/reset/<%= token %>" class="form">
    <label><%= t('new_password_min8') %></label>
    <input type="password" name="password" required minlength="8" placeholder="********" />

    <label><%= t('confirm_password') %></label>
    <input type="password" name="confirm" required minlength="8" placeholder="********" />

    <button type="submit"><%= t('update_password') %></button>
  </form>

  <p class="muted"><a href="/auth/login"><%= t('back_to_login') %></a></p>
</section>

<%- include("partials/footer") %>
