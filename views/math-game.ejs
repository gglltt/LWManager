<%- include("partials/header") %>

<section class="math-game-page mathGameShell" data-locale="<%= localeTag %>">
  <div class="math-game-shell">
  <div class="mathHero">
    <div>
      <p class="eyebrow">Math Challenge</p>
      <h1><%= t('mathGame.title') %></h1>
    </div>
    <div class="mathHeroActions" aria-label="Math game actions">
      <button id="mathHelpBtn" class="button mathAudioToggle" type="button" aria-label="<%= t('mathGame.howToPlay') %>">?</button>
      <button id="leaderboardBtn" class="button mathAction mathLeaderboardBtn" type="button">🏆 <span><%= t('mathGame.leaderboard') %></span></button>
      <button id="startGameBtn" class="button mathAction mathStart" type="button"><span>▶</span> <%= t('mathGame.start') %></button>
      <button id="audioToggleBtn" class="button mathAudioToggle" type="button" aria-label="Audio">🔊</button>
    </div>
  </div>

  <div class="mathPhoneCard" aria-live="polite">
    <div class="mathDashboard">
      <div class="mathStats">
        <span><%= t('mathGame.level') %> <b id="levelValue">1</b></span>
        <span><%= t('mathGame.completedLevels') %> <b id="completedValue">0</b></span>
        <span><%= t('mathGame.totalTime') %> <b id="totalTimeValue">0.0s</b></span>
      </div>
      <div class="levelBadge" id="levelBadge">Riscaldamento</div>
      <div class="mathProblem" id="challengeText">—</div>
      <div class="mathTimer" id="mathTimer" title="<%= t('mathGame.remainingTime') %>">
        <span id="remainingValue">10</span><small>s</small>
      </div>
    </div>

    <div class="answerZone" id="answerZone">
      <span class="answerLabel"><%= t('mathGame.answer') %></span>
      <div class="answerDisplay" id="answerDisplay">0</div>
      <div class="answerFeedback" id="answerFeedback"></div>
      <div class="comboBadge" id="comboBadge" aria-live="polite"></div>
    </div>

    <div class="keypad" aria-label="<%= t('mathGame.answer') %>">
      <% [1,2,3,4,5,6,7,8,9].forEach((n) => { %>
        <button class="numKey" type="button" data-number="<%= n %>"><%= n %></button>
      <% }) %>
      <button class="numKey command clear" type="button" id="clearBtn"><%= t('mathGame.clear') %></button>
      <button class="numKey" type="button" data-number="0">0</button>
      <button class="numKey command confirm" type="button" id="confirmBtn"><%= t('mathGame.confirm') %></button>
    </div>
  </div>

  </div>

  <div class="toast" id="mathToast" role="status" aria-live="polite"></div>

  <div class="math-game-modal-overlay" id="gameOverModal" role="dialog" aria-modal="true" aria-labelledby="gameOverTitle" aria-hidden="true">
    <div class="math-game-modal game-over-dialog">
    <h2 id="gameOverTitle"><%= t('mathGame.gameOver') %></h2>
    <div class="gameOverStats">
      <span><%= t('mathGame.reachedLevel') %>: <b id="overReached">1</b></span>
      <span><%= t('mathGame.completedLevels') %>: <b id="overCompleted">0</b></span>
      <span><%= t('mathGame.totalTime') %>: <b id="overTime">0.0s</b></span>
    </div>
    <label class="playerNameLabel" for="playerName"><%= t('mathGame.playerName') %></label>
    <input id="playerName" maxlength="30" pattern="[A-Za-z0-9 _-]{1,30}" autocomplete="nickname" placeholder="Biss_Player" />
    <p class="formMessage" id="scoreMessage"></p>
    <div class="gameOverActions">
      <button id="confirmScoreBtn" class="button" type="button">Salva risultato</button>
      <button id="closeGameOverBtn" class="button secondary" type="button">Chiudi</button>
    </div>
    </div>
  </div>

  <div class="math-game-modal-overlay" id="leaderboardModal" role="dialog" aria-modal="true" aria-labelledby="leaderboardTitle" aria-hidden="true">
    <div class="math-game-modal leaderboardModal">
      <div class="modalHeader">
        <h2 id="leaderboardTitle">🏆 <%= t('mathGame.leaderboard') %></h2>
        <button id="closeLeaderboardBtn" class="modalClose" type="button" aria-label="Close">×</button>
      </div>
      <div class="leaderboardList" id="leaderboardList">
        <div class="leaderboardEmpty"><%= t('mathGame.loading') %></div>
      </div>
    </div>
  </div>

  <div class="math-game-modal-overlay" id="mathHelpModal" role="dialog" aria-modal="true" aria-labelledby="mathHelpTitle" aria-hidden="true">
    <div class="math-game-modal mathHelpModal">
      <div class="modalHeader"><h2 id="mathHelpTitle">📖 <%= t('mathGame.howToPlay') %></h2><button id="closeMathHelpBtn" class="modalClose" type="button" aria-label="Close">×</button></div>
      <div class="mathHelpContent">
        <h3>🎯 <%= t('mathGame.title') %></h3><p><%= t('mathGame.helpIntro') %></p>
        <h3>⏱ <%= t('mathGame.remainingTime') %></h3><p><%= t('mathGame.helpTimer') %></p>
        <h3>📈 <%= t('mathGame.level') %></h3><p><%= t('mathGame.helpDifficulty') %></p>
        <h3>🏆 <%= t('mathGame.leaderboard') %></h3><p><%= t('mathGame.helpProgress') %></p>
      </div>
    </div>
  </div>
</section>

<script id="mathGameTranslations" type="application/json"><%- JSON.stringify({
  correct: t('mathGame.correct'),
  wrong: t('mathGame.wrong'),
  invalidName: t('mathGame.invalidName'),
  scoreSaved: t('mathGame.scoreSaved'),
  rank: t('mathGame.rank'),
  levels: t('mathGame.levels'),
  time: t('mathGame.time'),
  date: t('mathGame.date'),
  noScores: t('mathGame.noScores'),
  saveError: t('mathGame.saveError')
}) %></script>

<%- include("partials/footer") %>
