<%- include("../partials/header") %>
<section class="card cardWide alliancesPage">
  <div class="pageHeader">
    <div>
      <h1><%= t('alliances_management') %></h1>
      <p class="muted"><%= t('alliances_management_desc') %></p>
    </div>
    <a class="button secondary" href="/admin">← <%= t('admin_title') %></a>
  </div>

  <% if (message) { %><div class="alert success"><%= message %></div><% } %>
  <% if (error) { %><div class="alert error"><%= error %></div><% } %>

  <section class="adminSection allianceCreatePanel">
    <h2><%= t('new_alliance') %></h2>
    <form method="post" action="/admin/alliances" class="allianceCreateForm">
      <label class="field"><span><%= t('alliance_code') %></span><input type="text" name="code" required /></label>
      <label class="field"><span><%= t('server') %></span><input type="text" name="serverNumber" required inputmode="numeric" /></label>
      <label class="field"><span><%= t('display_name') %></span><input type="text" name="displayName" /></label>
      <label class="field"><span><%= t('standard_pin') %></span><input type="password" name="standardPin" required pattern="\d{6}" inputmode="numeric" placeholder="000000" /></label>
      <label class="field"><span><%= t('supervisor_pin') %></span><input type="password" name="supervisorPin" required pattern="\d{6}" inputmode="numeric" placeholder="000000" /></label>
      <button class="button" type="submit"><%= t('create_alliance') %></button>
    </form>
  </section>

  <div class="allianceList">
    <% alliances.forEach(a=>{ %>
      <article class="allianceCard">
        <div class="allianceCard__main">
          <div class="allianceBadge">#<%= a.allianceId %></div>
          <div>
            <h2><%= a.displayName || a.code %></h2>
            <div class="allianceMeta">
              <span><%= t('alliance_code') %>: <b><%= a.code %></b></span>
              <span><%= t('server') %>: <b><%= a.serverNumber %></b></span>
              <span class="statusPill <%= a.isActive ? 'statusPill--active' : 'statusPill--inactive' %>"><%= a.isActive ? t('active') : t('inactive') %></span>
              <span><%= t('created_at') %>: <b><%= a.createdAt ? new Date(a.createdAt).toLocaleString(localeTag) : '-' %></b></span>
            </div>
          </div>
        </div>
        <div class="allianceActions">
          <% if (a.isActive) { %>
            <form method="post" action="/admin/alliances/<%= a.allianceId %>/deactivate"><button class="button secondary" type="submit"><%= t('deactivate_alliance') %></button></form>
          <% } else { %>
            <form method="post" action="/admin/alliances/<%= a.allianceId %>/activate"><button class="button secondary" type="submit"><%= t('activate_alliance') %></button></form>
          <% } %>
          <form method="post" action="/admin/alliances/<%= a.allianceId %>/delete"><button class="button button--danger" type="submit"><%= t('delete_alliance') %></button></form>
          <form method="post" action="/admin/alliances/<%= a.allianceId %>/update-pins" class="alliancePinForm">
            <input type="password" name="standardPin" pattern="\d{6}" inputmode="numeric" placeholder="<%= t('standard_pin') %>" />
            <input type="password" name="supervisorPin" pattern="\d{6}" inputmode="numeric" placeholder="<%= t('supervisor_pin') %>" />
            <button class="button secondary"><%= t('update_pin') %></button>
          </form>
        </div>
      </article>
    <% }) %>
  </div>
</section>
<%- include("../partials/footer") %>
