<%- include("../partials/header") %>
<section class="card cardWide">
<h1><%= t('alliances_management') %></h1>
<a class="button secondary" href="/admin">← <%= t('admin_title') %></a>
<% if (message) { %><div class="alert success"><%= message %></div><% } %>
<% if (error) { %><div class="alert error"><%= error %></div><% } %>
<section class="adminSection"><h2><%= t('new_alliance') %></h2><form method="post" action="/admin/alliances" class="filterBar"><input name="code" required placeholder="<%= t('alliance_code') %>" /><input name="serverNumber" required inputmode="numeric" placeholder="<%= t('server') %>" /><input name="displayName" placeholder="<%= t('display_name') %>" /><input name="adminPin" required pattern="\d{6}" placeholder="<%= t('standard_pin') %>" /><input name="supervisorPin" required pattern="\d{6}" placeholder="<%= t('supervisor_pin') %>" /><button class="button" type="submit"><%= t('create_alliance') %></button></form></section>
<div class="tableWrap"><table class="table"><thead><tr><th>ID</th><th><%= t('alliance_code') %></th><th><%= t('server') %></th><th><%= t('display_name') %></th><th><%= t('status') %></th><th><%= t('created_at') %></th><th><%= t('actions') %></th></tr></thead><tbody><% alliances.forEach(a=>{ %><tr><td><%= a.allianceId %></td><td><%= a.code %></td><td><%= a.serverNumber %></td><td><%= a.displayName || '-' %></td><td><%= a.isActive ? 'Active' : 'Inactive' %></td><td><%= a.createdAt ? new Date(a.createdAt).toLocaleString(localeTag) : '-' %></td><td><form method="post" action="/admin/alliances/<%= a.allianceId %>/deactivate" style="display:inline"><button class="button secondary" type="submit"><%= t('deactivate_alliance') %></button></form><form method="post" action="/admin/alliances/<%= a.allianceId %>/delete" style="display:inline"><button class="button button--danger" type="submit"><%= t('delete_alliance') %></button></form><form method="post" action="/admin/alliances/<%= a.allianceId %>/update-pins" class="filterBar"><input name="adminPin" pattern="\d{6}" placeholder="<%= t('standard_pin') %>" /><input name="supervisorPin" pattern="\d{6}" placeholder="<%= t('supervisor_pin') %>" /><button class="button secondary"><%= t('update_pin') %></button></form></td></tr><% }) %></tbody></table></div>
</section>
<%- include("../partials/footer") %>
