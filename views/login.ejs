<%- include("partials/header") %>

<section class="card">
  <h1><%= t('login_title') %></h1>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form method="POST" action="/auth/login" class="form">
    <label><%= t('login_pin_label') %></label>
    <input type="password" name="pin" required minlength="6" maxlength="6" inputmode="numeric" pattern="\d{6}" placeholder="••••••" />

    <button type="submit"><%= t('login_button') %></button>
  </form>

  <p class="muted">
    <%= t('login_desc') %>
  </p>

  <div class="card" style="margin-top: 12px;">
    <h2 style="margin-top: 0;"><%= t('login_first_access') %></h2>
    <ol style="margin-top: 0;">
      <li><%= t('login_step_1') %></li>
      <li><%= t('login_step_2') %></li>
      <li><%= t('login_step_3') %></li>
      <li><%= t('login_step_4') %></li>
    </ol>
  </div>
</section>

<%- include("partials/footer") %>
