<%- include("partials/header") %>

<section class="card minigamesPage" aria-labelledby="minigamesTitle">
  <header class="minigamesPage__header">
    <h1 id="minigamesTitle"><%= t('minigames.title') %></h1>
    <p><%= t('minigames.subtitle') %></p>
  </header>

  <div class="minigamesGrid">
    <article class="minigameCard">
      <div class="minigameCard__icon" aria-hidden="true">∑</div>
      <div class="minigameCard__content">
        <h2><%= t('minigames.mathTitle') %></h2>
        <p><%= t('minigames.mathDesc') %></p>
      </div>
      <a class="button minigameCard__action" href="/math-game"><%= t('minigames.play') %></a>
    </article>

    <% if (showWordGame) { %>
      <article class="minigameCard">
        <div class="minigameCard__icon" aria-hidden="true">Aa</div>
        <div class="minigameCard__content">
          <h2><%= t('minigames.wordTitle') %></h2>
          <p><%= t('minigames.wordDesc') %></p>
        </div>
        <a
          class="button minigameCard__action"
          href="/word-game"
          data-word-game-launch
          data-loading-label="<%= t('wordGame.loadingWords') %>"><%= t('minigames.play') %></a>
      </article>
    <% } %>
  </div>
</section>

<%- include("partials/footer") %>
