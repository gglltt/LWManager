<%- include("../partials/header") %>

<%
  function fmt2(v) {
    if (v === null || v === undefined || v === "") return "-";
    const n = Number(v);
    if (Number.isNaN(n)) return "-";
    return n.toLocaleString(localeTag, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function fmtDate(d) {
    if (!d) return { dateStr: "-", timeStr: "-" };
    const dt = new Date(d);
    if (Number.isNaN(dt.getTime())) return { dateStr: "-", timeStr: "-" };
    const dateStr = dt.toLocaleDateString(localeTag);
    const timeStr = dt.toLocaleTimeString(localeTag, { hour: "2-digit", minute: "2-digit" });
    return { dateStr, timeStr };
  }

  function sortLink(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";

    let nextDir = "asc";
    if (currentSort === field && currentDir === "asc") nextDir = "desc";
    if (currentSort === field && currentDir === "desc") nextDir = "asc";

    const params = new URLSearchParams({ sort: field, dir: nextDir });
    if (q && String(q).trim().length > 0) params.set("q", String(q).trim());
    return `/potenze?${params.toString()}`;
  }

  function sortArrow(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";
    if (currentSort !== field) return "";
    return currentDir === "asc" ? " ▲" : " ▼";
  }

  function pseudoBold(text) {
    const src = String(text || "");
    const bolded = Array.from(src).map((ch) => {
      const code = ch.codePointAt(0);
      if (code >= 65 && code <= 90) return String.fromCodePoint(0x1D5D4 + (code - 65)); // A-Z
      if (code >= 97 && code <= 122) return String.fromCodePoint(0x1D5EE + (code - 97)); // a-z
      if (code >= 48 && code <= 57) return String.fromCodePoint(0x1D7EC + (code - 48)); // 0-9
      return ch;
    });
    return bolded.join("");
  }

  function tooltipText(p) {
    const parts = [];
    const originalNotes = p.notes && String(p.notes).trim().length > 0 ? String(p.notes).trim() : "";
    if (originalNotes) {
      parts.push(`${pseudoBold(t("notes_optional_tp"))}: ${originalNotes}`);
      if (p.autoTranslatedNote && String(p.autoTranslatedNote).trim().length > 0) {
        parts.push(`${pseudoBold(`${t("translation_prefix")} (${t("translation_auto_suffix")})`)}: ${String(p.autoTranslatedNote).trim()}`);
      }
    }
    parts.push(`${pseudoBold(t("updated_at"))}: ${p.updatedAt ? new Date(p.updatedAt).toLocaleString(localeTag) : "-"}`);
    return parts.join("\n");
  }

  function labelType(tLabel, tType) {
    const type = tType && String(tType).trim().length > 0 ? translateTeamType(String(tType).trim()) : "-";
    return `${tLabel}:${type}`;
  }
%>

<section class="card cardWide">
  <div class="pageHeader">
    <div>
      <h1><%= t("powers_title") %></h1>
      <p class="muted"><%= t("powers_mobile_desc") %></p>
      <p><strong><%= t("players_registered") %>: <%= playerCount %></strong></p>
      <p class="muted"><%= t("current_role") %>: <b><%= isAdmin ? t("admin") : t("standard") %></b></p>
    </div>

    <div class="pageHeaderActions">
      <a class="button secondary" href="/dashboard">← <%= t("back_dashboard") %></a>
      <% if (isAdmin) { %>
        <a class="button secondary" href="/potenze/export">⬇️ Export Excel</a>
      <% } else { %>
        <span class="muted" title="<%= t('export_requires_admin_pin') %>"><%= t("export_admin_only") %></span>
      <% } %>
      <a class="button" href="/potenze/new"><%= t("new_player_button") %></a>
    </div>
  </div>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form method="GET" action="/potenze" class="filterBar">
    <input type="hidden" name="sort" value="<%= sort %>" />
    <input type="hidden" name="dir" value="<%= dir %>" />
    <input
      type="text"
      name="q"
      value="<%= q || "" %>"
      placeholder="<%= t('nickname_filter_placeholder') %>"
      class="filterInput"
    />
    <button type="submit" class="button"><%= t("search") %></button>
    <% if (q && String(q).trim().length > 0) { %>
      <a class="button secondary" href="/potenze?sort=<%= encodeURIComponent(sort) %>&dir=<%= encodeURIComponent(dir) %>" title="<%= t('remove_filter') %>">✕</a>
    <% } %>
  </form>

  <!-- MOBILE: quick sort bar -->
  <div class="sortBar">
    <span class="muted"><%= t("sort_by") %>:</span>
    <a class="sortPill" href="<%= sortLink('nickname') %>">Nick<%= sortArrow('nickname') %></a>
    <a class="sortPill" href="<%= sortLink('powerT1') %>">T1<%= sortArrow('powerT1') %></a>
    <a class="sortPill" href="<%= sortLink('total') %>">Tot<%= sortArrow('total') %></a>
    <a class="sortPill" href="<%= sortLink('updatedAt') %>">Data<%= sortArrow('updatedAt') %></a>
  </div>

  <!-- MOBILE: cards -->
  <div class="playerCards">
    <% if (!players || players.length === 0) { %>
      <div class="muted"><%= t("no_players") %></div>
    <% } %>

    <% (players || []).forEach(p => { 
      const dt = fmtDate(p.updatedAt);
    %>
      <div class="playerCard" title="<%= tooltipText(p) %>">
        <div class="playerCardTop">
          <div class="playerTitle">
            <div class="playerTitleLine">
              <span class="playerNick"><%= p.nickname %></span>
              <span class="playerMeta muted">
                <span>- <%= p.role || "-" %></span>
                <span>- <%= fmt2(p.total) %></span>
              </span>
            </div>
          </div>

          <div class="playerActions">
            <a class="iconBtn" href="/potenze/<%= p._id %>/edit" title="<%= t('edit') %>">✏️</a>
            <button type="button" class="iconBtn playerHistoryOpenBtn" data-player-id="<%= p._id %>" data-player-name="<%= p.nickname %>" title="<%= t('history_chart') %>">📈</button>
            <% if (isAdmin) { %>
              <form method="POST" action="/potenze/<%= p._id %>/delete" class="inlineForm" onsubmit="return confirm('<%= t('confirm_delete_player') %> <%= p.nickname %>?');">
                <button class="iconBtn danger" type="submit" title="<%= t('delete') %>">🗑️</button>
              </form>
            <% } %>
          </div>
        </div>

        <div class="playerCardMid">
          <div class="powerGrid powerGrid4">
            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T1", p.typeT1) %></div>
              <div class="powerVal"><%= fmt2(p.powerT1) %></div>
            </div>

            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T2", p.typeT2) %></div>
              <div class="powerVal"><%= fmt2(p.powerT2) %></div>
            </div>

            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T3", p.typeT3) %></div>
              <div class="powerVal"><%= fmt2(p.powerT3) %></div>
            </div>

            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T4", p.typeT4) %></div>
              <div class="powerVal"><%= fmt2(p.powerT4) %></div>
            </div>
          </div>
        </div>

        <div class="playerCardBottom">
          <div class="dateBlock">
            <div class="dateTop">
              <%= dt.dateStr %>
              <span class="dateSub muted"><%= dt.timeStr %></span>
            </div>
          </div>

          <div class="notesHint muted">
            <% if (p.notes && String(p.notes).trim().length > 0) { %>
              <button
                type="button"
                class="iconBtn notesOpenBtn"
                data-player-notes="<%= String(p.notes).trim() %>"
                data-player-nickname="<%= p.nickname %>">
                📝 <%= t("notes_short") %>
              </button>
            <% } else { %>
              &nbsp;
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- DESKTOP: table -->
  <div class="tableWrap desktopOnly">
    <table class="table tableCompact">
      <thead>
        <tr>
          <th class="colNick"><a class="thLink" href="<%= sortLink('nickname') %>">Nick<%= sortArrow('nickname') %></a></th>
          <th class="colRole"><a class="thLink" href="<%= sortLink('role') %>"><%= sortArrow('role') %></a></th>

          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT1') %>">T1<%= sortArrow('powerT1') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT2') %>">T2<%= sortArrow('powerT2') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT3') %>">T3<%= sortArrow('powerT3') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT4') %>">T4<%= sortArrow('powerT4') %></a></th>

          <th class="colTotal"><a class="thLink" href="<%= sortLink('total') %>">Tot<%= sortArrow('total') %></a></th>
          <th class="colDate"><a class="thLink" href="<%= sortLink('updatedAt') %>">Data<%= sortArrow('updatedAt') %></a></th>

          <th class="colActions"><%= t("actions_short") %></th>
        </tr>
      </thead>

      <tbody>
        <% if (!players || players.length === 0) { %>
          <tr>
            <td colspan="9" class="muted"><%= t("no_players") %></td>
          </tr>
        <% } %>

        <% (players || []).forEach(p => {
          const dt = fmtDate(p.updatedAt);
        %>
          <tr title="<%= tooltipText(p) %>">
            <td class="colNick">
              <div class="cell2">
                <div class="cellTop"><b><%= p.nickname %></b></div>
                <div class="cellSub muted">
                  <% if (p.notes && String(p.notes).trim().length > 0) { %>
                    📝 <%= t("notes_short") %>
                  <% } else { %>
                    &nbsp;
                  <% } %>
                </div>
              </div>
            </td>

            <td class="colRole"><div class="cellSingle"><%= p.role || "-" %></div></td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT1) %></div>
                <div class="cellSub muted"><%= p.typeT1 ? translateTeamType(p.typeT1) : "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT2) %></div>
                <div class="cellSub muted"><%= p.typeT2 ? translateTeamType(p.typeT2) : "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT3) %></div>
                <div class="cellSub muted"><%= p.typeT3 ? translateTeamType(p.typeT3) : "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT4) %></div>
                <div class="cellSub muted"><%= p.typeT4 ? translateTeamType(p.typeT4) : "-" %></div>
              </div>
            </td>

            <td class="colTotal"><div class="cellSingle"><b><%= fmt2(p.total) %></b></div></td>

            <td class="colDate">
              <div class="cell2">
                <div class="cellTop"><%= dt.dateStr %></div>
                <div class="cellSub muted"><%= dt.timeStr %></div>
              </div>
            </td>

            <td class="colActions">
              <div class="actionIcons">
                <a class="iconBtn" href="/potenze/<%= p._id %>/edit" title="<%= t('edit') %>">✏️</a>
            <button type="button" class="iconBtn playerHistoryOpenBtn" data-player-id="<%= p._id %>" data-player-name="<%= p.nickname %>" title="<%= t('history_chart') %>">📈</button>
                <% if (isAdmin) { %>
                  <form method="POST" action="/potenze/<%= p._id %>/delete" class="inlineForm" onsubmit="return confirm('<%= t('confirm_delete_player') %> <%= p.nickname %>?');">
                    <button class="iconBtn danger" type="submit" title="<%= t('delete') %>">🗑️</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (!isAdmin) { %>
    <p class="muted" style="margin-top: 12px;">
      <%= t("standard_mode_hint") %>
    </p>
  <% } %>
</section>


<div class="logModal" id="playerHistoryModal" hidden aria-hidden="true">
  <div class="logModalBackdrop" data-player-history-close="true"></div>
  <div class="logModalDialog logModalDialogWide" role="dialog" aria-modal="true" aria-labelledby="playerHistoryModalTitle">
    <div class="logModalHeader">
      <h3 id="playerHistoryModalTitle"><%= t("history_chart") %></h3>
      <button type="button" class="iconBtn" id="playerHistoryModalClose" aria-label="<%= t('close') %>">✖</button>
    </div>
    <div class="historyMeta muted" id="playerHistoryMeta"></div>
    <div class="historyScaleControls" id="historyScaleControls">
      <span class="historyScaleLabel"><%= t('scale') %></span>
      <button type="button" class="historyScaleBtn " data-history-scale="daily" aria-pressed="false"><%= t('daily') %></button>
      <button type="button" class="historyScaleBtn isActive" data-history-scale="weekly" aria-pressed="true"><%= t('weekly') %></button>
    </div>
    <div class="historyChartWrap">
      <canvas id="playerHistoryCanvas" height="320"></canvas>
    </div>
    <div class="historyLegend" id="playerHistoryLegend"></div>
    <div class="tableWrap historyTableWrap">
      <table class="table tableCompact">
        <thead>
          <tr>
            <th><%= t("date") %></th>
            <th>T1</th>
            <th>T2</th>
            <th>T3</th>
            <th>T4</th>
          </tr>
        </thead>
        <tbody id="playerHistoryTableBody">
          <tr><td colspan="5" class="muted"><%= t("history_loading") %></td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="logModal" id="playerNotesModal" hidden aria-hidden="true">
  <div class="logModalBackdrop" data-player-notes-close="true"></div>
  <div class="logModalDialog" role="dialog" aria-modal="true" aria-labelledby="playerNotesModalTitle">
    <div class="logModalHeader">
      <h3 id="playerNotesModalTitle"><%= t("notes_details") %></h3>
      <button type="button" class="iconBtn" id="playerNotesTranslateBtn" aria-label="<%= t('translate_note') %>" title="<%= t('translate_note') %>">🌐</button>
      <button type="button" class="iconBtn" id="playerNotesModalClose" aria-label="<%= t('close') %>">✖</button>
    </div>
    <pre class="logModalBody" id="playerNotesModalBody"></pre>
  </div>
</div>

<script>
  (function () {
    const modal = document.getElementById("playerNotesModal");
    const modalBody = document.getElementById("playerNotesModalBody");
    const closeBtn = document.getElementById("playerNotesModalClose");
    const translateBtn = document.getElementById("playerNotesTranslateBtn");
    const targetLang = "<%= currentLang %>";
    const translationPrefix = "<%= t('translation_prefix') %>";
    const translatingLabel = "<%= t('translating_note') %>";
    const translationError = "<%= t('translation_error') %>";
    const sameLanguageMsg = "<%= t('translation_same_language') %>";
    if (!modal || !modalBody || !closeBtn || !translateBtn) return;

    let originalText = "";
    let translatedText = "";
    let sourceLang = "";

    function closeModal() {
      modal.hidden = true;
      modalBody.textContent = "";
      modal.setAttribute("aria-hidden", "true");
      translateBtn.disabled = false;
      originalText = "";
      translatedText = "";
      sourceLang = "";
    }

    function openModal(text) {
      originalText = String(text || "").trim();
      translatedText = "";
      sourceLang = "";
      modalBody.textContent = originalText;
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
    }

    function buildBodyText() {
      if (!translatedText) return originalText;
      const langInfo = sourceLang ? `${sourceLang} → ${targetLang}` : targetLang;
      return `${originalText}\n\n────────\n${translationPrefix} (${langInfo}):\n${translatedText}`;
    }

    document.querySelectorAll("[data-player-notes]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const nickname = btn.getAttribute("data-player-nickname") || "-";
        const notes = btn.getAttribute("data-player-notes") || "-";
        openModal(`${nickname}\n\n${notes}`);
      });
    });

    closeBtn.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      closeModal();
    });

    modal.addEventListener("click", (event) => {
      const target = event.target;
      if (target && target.closest("[data-player-notes-close='true']")) {
        closeModal();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !modal.hidden) {
        closeModal();
      }
    });

    translateBtn.addEventListener("click", async () => {
      if (!originalText) return;
      translateBtn.disabled = true;
      modalBody.textContent = `${buildBodyText()}\n\n${translatingLabel}`;

      try {
        const resp = await fetch("/potenze/translate-note", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ text: originalText, targetLang })
        });
        const data = await resp.json();

        if (!resp.ok || !data?.ok) {
          modalBody.textContent = `${buildBodyText()}\n\n${translationError}`;
          return;
        }

        if (data.sameLanguage) {
          modalBody.textContent = `${buildBodyText()}\n\n${sameLanguageMsg}`;
          return;
        }

        translatedText = String(data.translatedText || "").trim();
        sourceLang = String(data.sourceLang || "").trim().toLowerCase();
        modalBody.textContent = buildBodyText();
      } catch (err) {
        modalBody.textContent = `${buildBodyText()}\n\n${translationError}`;
      } finally {
        translateBtn.disabled = false;
      }
    });

    const historyModal = document.getElementById("playerHistoryModal");
    const historyCloseBtn = document.getElementById("playerHistoryModalClose");
    const historyMeta = document.getElementById("playerHistoryMeta");
    const historyTableBody = document.getElementById("playerHistoryTableBody");
    const historyCanvas = document.getElementById("playerHistoryCanvas");
    const historyLegend = document.getElementById("playerHistoryLegend");

    const seriesConfig = [
      { key: "t1", label: "T1", color: "#3a67ff" },
      { key: "t2", label: "T2", color: "#2bd576" },
      { key: "t3", label: "T3", color: "#ffaf45" },
      { key: "t4", label: "T4", color: "#ff5c7a" },
      { key: "total", label: "TOT", color: "#b86bff" }
    ];
    const seriesVisibility = Object.fromEntries(seriesConfig.map((serie) => [serie.key, serie.key !== "total"]));
    let currentChartPoints = [];
    let currentHistoryScale = "weekly";

    const formatPointValue = (value) => Number(value || 0).toLocaleString("it-IT", { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    function getWeeklyTickDays(points) {
      if (!Array.isArray(points) || points.length === 0) return new Set();
      const lastDate = new Date(`${points[points.length - 1].date}T00:00:00Z`);
      if (Number.isNaN(lastDate.getTime())) return new Set();
      const month = lastDate.getUTCMonth();
      const ticks = new Set();
      for (let cursor = new Date(lastDate); cursor.getUTCMonth() === month; cursor = new Date(cursor.getTime() - 7 * 24 * 60 * 60 * 1000)) {
        ticks.add(toIsoDayUTC(cursor));
      }
      return ticks;
    }

    const hasRealEntry = (point) => point?._real === true;
    function shouldShowXAxisLabel(point, weeklyTickDays) {
      if (currentHistoryScale === "daily") return true;
      return hasRealEntry(point) || weeklyTickDays.has(point.date);
    }

    function closeHistoryModal() {
      if (!historyModal) return;
      historyModal.hidden = true;
      historyModal.setAttribute("aria-hidden", "true");
    }

    function openHistoryModal() {
      if (!historyModal) return;
      historyModal.hidden = false;
      historyModal.setAttribute("aria-hidden", "false");
    }

    function getVisibleSeries() {
      return seriesConfig.filter((serie) => seriesVisibility[serie.key] !== false);
    }

    function resizeHistoryCanvas() {
      if (!historyCanvas) return;
      const cssWidth = Math.max(320, Math.floor(historyCanvas.clientWidth || 980));
      const cssHeight = 320;

      if (historyCanvas.width !== cssWidth || historyCanvas.height !== cssHeight) {
        historyCanvas.width = cssWidth;
        historyCanvas.height = cssHeight;
      }
    }

    function drawHistoryChart(points) {
      if (!historyCanvas) return;
      resizeHistoryCanvas();
      const ctx = historyCanvas.getContext("2d");
      const w = historyCanvas.width;
      const h = historyCanvas.height;
      const pad = { l: 56, r: 78, t: 16, b: 74 };
      const chartW = w - pad.l - pad.r;
      const chartH = h - pad.t - pad.b;
      const visibleSeries = getVisibleSeries();

      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = "#0d1424";
      ctx.fillRect(0, 0, w, h);

      if (!points || points.length === 0) {
        ctx.fillStyle = "#a9b6d3";
        ctx.font = "14px sans-serif";
        ctx.fillText("Nessun dato", 20, 26);
        return;
      }

      const numericValues = points.flatMap((point) =>
        visibleSeries
          .map((serie) => point[serie.key])
          .filter((value) => Number.isFinite(value))
      );
      const maxY = Math.max(1, ...(numericValues.length ? numericValues : [0]));
      const minY = 0;

      ctx.strokeStyle = "rgba(169,182,211,.25)";
      ctx.lineWidth = 1;
      for (let i = 0; i <= 5; i++) {
        const yy = pad.t + (chartH * i) / 5;
        ctx.beginPath();
        ctx.moveTo(pad.l, yy);
        ctx.lineTo(w - pad.r, yy);
        ctx.stroke();

        const val = (maxY - ((maxY - minY) * i) / 5).toFixed(0);
        ctx.fillStyle = "#a9b6d3";
        ctx.font = "11px sans-serif";
        ctx.fillText(val, 4, yy + 4);
      }

      const xForIndex = (i) => pad.l + (points.length === 1 ? chartW / 2 : (chartW * i) / (points.length - 1));
      const yForValue = (v) => pad.t + chartH - ((v - minY) / (maxY - minY)) * chartH;

      points.forEach((point, i) => {
        if (!hasRealEntry(point)) return;
        const x = xForIndex(i);
        ctx.save();
        ctx.setLineDash([4, 4]);
        ctx.strokeStyle = "rgba(184,107,255,.4)";
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(x, pad.t);
        ctx.lineTo(x, pad.t + chartH);
        ctx.stroke();
        ctx.restore();
      });

      const weeklyTickDays = getWeeklyTickDays(points);
      points.forEach((p, i) => {
        if (!shouldShowXAxisLabel(p, weeklyTickDays)) return;
        const x = xForIndex(i);
        ctx.save();
        ctx.translate(x, h - 6);
        ctx.rotate(-Math.PI / 3);
        ctx.fillStyle = hasRealEntry(p) ? "#d4dcf0" : "#a9b6d3";
        ctx.font = "14px sans-serif";
        ctx.fillText(p.date.slice(5), 0, 0);
        ctx.restore();
      });

      visibleSeries.forEach((serie) => {
        ctx.beginPath();
        ctx.lineWidth = 2;
        ctx.strokeStyle = serie.color;
        ctx.lineJoin = "round";
        ctx.lineCap = "round";
        let hasPath = false;
        points.forEach((point, i) => {
          const rawValue = point[serie.key];
          if (!Number.isFinite(rawValue)) {
            hasPath = false;
            return;
          }
          const x = xForIndex(i);
          const y = yForValue(rawValue);
          if (!hasPath) {
            ctx.moveTo(x, y);
            hasPath = true;
          } else {
            ctx.lineTo(x, y);
          }
        });
        ctx.stroke();

        let lastPoint = null;
        for (let i = points.length - 1; i >= 0; i--) {
          const point = points[i];
          const rawValue = point[serie.key];
          if (!Number.isFinite(rawValue)) continue;
          lastPoint = { index: i, value: rawValue };
          break;
        }
        if (!lastPoint) return;

        const labelX = Math.min(w - pad.r + 6, xForIndex(lastPoint.index) + 8);
        const labelY = yForValue(lastPoint.value);
        ctx.fillStyle = serie.color;
        ctx.font = "bold 11px sans-serif";
        ctx.textBaseline = "middle";
        ctx.fillText(`${serie.label} ${formatPointValue(lastPoint.value)}`, labelX, labelY);
      });
    }

    function renderLegend() {
      if (!historyLegend) return;
      historyLegend.innerHTML = seriesConfig
        .map((serie) => {
          const inactiveClass = seriesVisibility[serie.key] === false ? " legendItemOff" : "";
          return `<button type="button" class="legendItem${inactiveClass}" data-series-key="${serie.key}" aria-pressed="${seriesVisibility[serie.key] !== false}"><span class="legendDot" style="background:${serie.color}"></span>${serie.label}</button>`;
        })
        .join("");

      historyLegend.querySelectorAll("[data-series-key]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.getAttribute("data-series-key");
          if (!key || !(key in seriesVisibility)) return;
          seriesVisibility[key] = !seriesVisibility[key];
          renderLegend();
          drawHistoryChart(currentChartPoints);
        });
      });
    }

    function setupScaleControls() {
      const controls = document.getElementById("historyScaleControls");
      if (!controls) return;
      controls.querySelectorAll("[data-history-scale]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const selected = btn.getAttribute("data-history-scale");
          if (!selected || (selected !== "daily" && selected !== "weekly")) return;
          currentHistoryScale = selected;
          controls.querySelectorAll("[data-history-scale]").forEach((item) => {
            const active = item.getAttribute("data-history-scale") === currentHistoryScale;
            item.classList.toggle("isActive", active);
            item.setAttribute("aria-pressed", active ? "true" : "false");
          });
          drawHistoryChart(currentChartPoints);
        });
      });
    }

    function toIsoDayUTC(dateObj) {
      const y = dateObj.getUTCFullYear();
      const m = String(dateObj.getUTCMonth() + 1).padStart(2, "0");
      const d = String(dateObj.getUTCDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    function buildLastDaysForChart(realRows, daysCount) {
      const count = Number.isFinite(daysCount) ? Math.max(1, Math.floor(daysCount)) : 30;
      const rowsByDay = new Map(
        (realRows || [])
          .filter((row) => row && row.date)
          .map((row) => [String(row.date), row])
      );

      const now = new Date();
      const startUTC = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() - (count - 1), 0, 0, 0, 0));
      const result = [];
      let lastKnown = null;
      for (let i = 0; i < count; i++) {
        const dayUTC = new Date(startUTC.getTime() + i * 24 * 60 * 60 * 1000);
        const isoDay = toIsoDayUTC(dayUTC);
        const realRow = rowsByDay.get(isoDay);
        if (realRow) {
          const normalized = {
            date: isoDay,
            t1: Number(realRow.t1 || 0),
            t2: Number(realRow.t2 || 0),
            t3: Number(realRow.t3 || 0),
            t4: Number(realRow.t4 || 0),
            total: Number(realRow.total || 0),
            _real: true
          };
          result.push(normalized);
          lastKnown = normalized;
        } else {
          if (!lastKnown) {
            result.push({
              date: isoDay,
              t1: 0,
              t2: 0,
              t3: 0,
              t4: 0,
              total: 0,
              _real: false
            });
            continue;
          }
          result.push({
            date: isoDay,
            t1: lastKnown.t1,
            t2: lastKnown.t2,
            t3: lastKnown.t3,
            t4: lastKnown.t4,
            total: lastKnown.total,
            _real: false
          });
        }
      }
      return result;
    }

    async function openPlayerHistory(playerId, playerName) {
      seriesConfig.forEach((serie) => {
        seriesVisibility[serie.key] = serie.key !== "total";
      });
      currentChartPoints = [];
      currentHistoryScale = "weekly";
      const controls = document.getElementById("historyScaleControls");
      if (controls) {
        controls.querySelectorAll("[data-history-scale]").forEach((item) => {
          const active = item.getAttribute("data-history-scale") === "weekly";
          item.classList.toggle("isActive", active);
          item.setAttribute("aria-pressed", active ? "true" : "false");
        });
      }
      openHistoryModal();
      historyMeta.textContent = `${playerName} · <%= t("last_month") %>`;
      historyTableBody.innerHTML = `<tr><td colspan="5" class="muted"><%= t("history_loading") %></td></tr>`;
      renderLegend();
      drawHistoryChart([]);

      try {
        const resp = await fetch(`/potenze/${playerId}/history-data?days=30`);
        const data = await resp.json();
        if (!resp.ok || !data?.ok) throw new Error("history_error");

        const rows = data.history || [];
        const chartRows = buildLastDaysForChart(rows, Number(data.days || 30));
        currentChartPoints = chartRows;
        if (!rows.length) {
          historyTableBody.innerHTML = `<tr><td colspan="5" class="muted"><%= t("no_history") %></td></tr>`;
          drawHistoryChart(chartRows);
          return;
        }

        const displayRows = rows.map((row, index) => {
          const prev = index > 0 ? rows[index - 1] : null;
          const showValue = (value, prevValue) => {
            const numericValue = Number(value || 0);
            const numericPrev = Number(prevValue || 0);
            if (!Number.isFinite(numericValue) || numericValue === 0) return "";
            if (prev && numericValue === numericPrev) return "";
            return numericValue;
          };

          return {
            date: row.date,
            t1: showValue(row.t1, prev?.t1),
            t2: showValue(row.t2, prev?.t2),
            t3: showValue(row.t3, prev?.t3),
            t4: showValue(row.t4, prev?.t4),
            total: showValue(row.total, prev?.total)
          };
        });

        historyTableBody.innerHTML = displayRows
          .map((row) => `<tr><td class="historyDateCell">${row.date}</td><td>${row.t1}</td><td>${row.t2}</td><td>${row.t3}</td><td>${row.t4}</td></tr>`)
          .join("");

        drawHistoryChart(chartRows);
      } catch (err) {
        historyTableBody.innerHTML = `<tr><td colspan="5" class="muted"><%= t("err_internal") %></td></tr>`;
      }
    }

    setupScaleControls();

    window.addEventListener("resize", () => {
      if (historyModal && !historyModal.hidden) {
        drawHistoryChart(currentChartPoints);
      }
    });

    document.querySelectorAll(".playerHistoryOpenBtn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const playerId = btn.getAttribute("data-player-id");
        const playerName = btn.getAttribute("data-player-name") || "-";
        if (!playerId) return;
        openPlayerHistory(playerId, playerName);
      });
    });

    if (historyCloseBtn) {
      historyCloseBtn.addEventListener("click", (event) => {
        event.preventDefault();
        closeHistoryModal();
      });
    }

    if (historyModal) {
      historyModal.addEventListener("click", (event) => {
        const target = event.target;
        if (target && target.closest("[data-player-history-close='true']")) {
          closeHistoryModal();
        }
      });
    }

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && historyModal && !historyModal.hidden) {
        closeHistoryModal();
      }
    });

  })();
</script>

