<%- include("../partials/header") %>

<%
  function fmt2(v) {
    if (v === null || v === undefined || v === "") return "-";
    const n = Number(v);
    if (Number.isNaN(n)) return "-";
    return n.toLocaleString(localeTag, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function fmtDate(d) {
    if (!d) return { dateStr: "-", timeStr: "-" };
    const dt = new Date(d);
    if (Number.isNaN(dt.getTime())) return { dateStr: "-", timeStr: "-" };
    const dateStr = dt.toLocaleDateString(localeTag);
    const timeStr = dt.toLocaleTimeString(localeTag, { hour: "2-digit", minute: "2-digit" });
    return { dateStr, timeStr };
  }

  function sortLink(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";

    let nextDir = "asc";
    if (currentSort === field && currentDir === "asc") nextDir = "desc";
    if (currentSort === field && currentDir === "desc") nextDir = "asc";

    const params = new URLSearchParams({ sort: field, dir: nextDir });
    if (q && String(q).trim().length > 0) params.set("q", String(q).trim());
    if (user && user.isMaster && tenantFilter && tenantFilter.allianceId) params.set("allianceId", String(tenantFilter.allianceId));
    return `/potenze?${params.toString()}`;
  }

  function sortArrow(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";
    if (currentSort !== field) return "";
    return currentDir === "asc" ? " ▲" : " ▼";
  }

  function pseudoBold(text) {
    const src = String(text || "");
    const bolded = Array.from(src).map((ch) => {
      const code = ch.codePointAt(0);
      if (code >= 65 && code <= 90) return String.fromCodePoint(0x1D5D4 + (code - 65)); // A-Z
      if (code >= 97 && code <= 122) return String.fromCodePoint(0x1D5EE + (code - 97)); // a-z
      if (code >= 48 && code <= 57) return String.fromCodePoint(0x1D7EC + (code - 48)); // 0-9
      return ch;
    });
    return bolded.join("");
  }

  function tooltipText(p) {
    const parts = [];
    const originalNotes = p.notes && String(p.notes).trim().length > 0 ? String(p.notes).trim() : "";
    if (originalNotes) {
      parts.push(`${pseudoBold(t("notes_optional_tp"))}: ${originalNotes}`);
      if (p.autoTranslatedNote && String(p.autoTranslatedNote).trim().length > 0) {
        parts.push(`${pseudoBold(`${t("translation_prefix")} (${t("translation_auto_suffix")})`)}: ${String(p.autoTranslatedNote).trim()}`);
      }
    }
    parts.push(`${pseudoBold(t("updated_at"))}: ${p.updatedAt ? new Date(p.updatedAt).toLocaleString(localeTag) : "-"}`);
    return parts.join("\n");
  }

  function labelType(tLabel, tType) {
    const type = tType && String(tType).trim().length > 0 ? translateTeamType(String(tType).trim()) : "-";
    return `${tLabel}:${type}`;
  }
%>

<section class="card cardWide">
  <header class="powersHeader">
    <div class="powersHeader__title">
      <h1><%= t("powers_title") %></h1>
    </div>

    <div class="powersHeader__actions">
      <% if (canExport) { %>
        <% const exportAllianceId = user && user.isMaster && tenantFilter && tenantFilter.allianceId ? Number(tenantFilter.allianceId) : null; %>
        <a class="button secondary" href="/potenze/export<%= exportAllianceId ? `?allianceId=${exportAllianceId}` : '' %>">⬇️ <%= t("export_excel") %></a>
      <% } %>
      <% if (typeof canEdit !== "undefined" ? canEdit : isAdmin) { %><a class="button" href="/potenze/new"><%= t("new_player_button") %></a><% } %>
    </div>

    <div class="powersHeader__meta">
      <span><%= t("players_registered") %>: <strong><%= playerCount %></strong></span>
      <span><%= t("current_role") %>: <strong><%= user && user.isMaster ? t("admin") : (user && user.role === "supervisor" ? t("supervisor") : t("standard")) %></strong></span>
    </div>
  </header>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form method="GET" action="/potenze" class="filterBar powersFilterBar <%= user && user.isMaster ? '' : 'powersFilterBar--singleTenant' %>">
    <input type="hidden" name="sort" value="<%= sort %>" />
    <input type="hidden" name="dir" value="<%= dir %>" />
    <% if (user && user.isMaster) { %>
      <select name="allianceId" class="filterInput powersFilterBar__alliance" aria-label="<%= t('select_alliance') %>">
        <option value=""><%= t("all_alliances") %></option>
        <% (alliances || []).forEach(a => { %>
          <option value="<%= a.allianceId %>" <%= Number(tenantFilter && tenantFilter.allianceId) === Number(a.allianceId) ? "selected" : "" %>><%= a.displayName || a.code %>#<%= a.serverNumber %></option>
        <% }) %>
      </select>
    <% } %>
    <input
      type="text"
      name="q"
      value="<%= q || "" %>"
      placeholder="<%= t('nickname_filter_placeholder') %>"
      class="filterInput powersFilterBar__nickname"
      aria-label="<%= t('nickname') %>"
    />
    <button type="submit" class="button powersFilterBar__submit"><%= t("search") %></button>
    <% if ((q && String(q).trim().length > 0) || (user && user.isMaster && tenantFilter && tenantFilter.allianceId)) { %>
      <a class="button secondary powersFilterBar__reset" href="/potenze?sort=<%= encodeURIComponent(sort) %>&dir=<%= encodeURIComponent(dir) %>" title="<%= t('remove_filter') %>"><%= t('reset') %></a>
    <% } %>
  </form>

  <!-- MOBILE: quick sort bar -->
  <div class="sortBar">
    <span class="muted"><%= t("sort_by") %>:</span>
    <a class="sortPill" href="<%= sortLink('nickname') %>"><%= t("nickname") %><%= sortArrow('nickname') %></a>
    <a class="sortPill" href="<%= sortLink('powerT1') %>">T1<%= sortArrow('powerT1') %></a>
    <a class="sortPill" href="<%= sortLink('total') %>"><%= t("total") %><%= sortArrow('total') %></a>
    <a class="sortPill" href="<%= sortLink('updatedAt') %>"><%= t("date") %><%= sortArrow('updatedAt') %></a>
  </div>

  <!-- MOBILE: cards -->
  <div class="playerCards">
    <% if (!players || players.length === 0) { %>
      <div class="muted"><%= t("no_players") %></div>
    <% } %>

    <% (players || []).forEach(p => { 
      const dt = fmtDate(p.updatedAt);
    %>
      <div class="playerCard" title="<%= tooltipText(p) %>">
        <div class="playerCardTop">
          <div class="playerTitle">
            <div class="playerTitleLine">
              <span class="playerNick"><%= p.nickname %></span>
              <span class="playerMeta muted">
                <span>- <%= p.role || "-" %></span>
                <span>- <%= fmt2(p.total) %></span>
              </span>
            </div>
          </div>

          <div class="playerActions">
            <a class="iconBtn" href="/potenze/<%= p._id %>/edit" title="<%= t('edit') %>" aria-label="<%= t('edit') %>: <%= p.nickname %>">✏️</a>
            <button type="button" class="iconBtn playerHistoryOpenBtn" data-player-id="<%= p._id %>" data-player-name="<%= p.nickname %>" title="<%= t('history_chart') %>" aria-label="<%= t('history_chart') %>: <%= p.nickname %>">📈</button>
            <% if (isAdmin) { %>
              <form method="POST" action="/potenze/<%= p._id %>/delete" class="inlineForm" onsubmit="return confirm('<%= t('confirm_delete_player') %> <%= p.nickname %>?');">
                <button class="iconBtn danger" type="submit" title="<%= t('delete') %>" aria-label="<%= t('delete') %>: <%= p.nickname %>">🗑️</button>
              </form>
            <% } %>
          </div>
        </div>

        <div class="playerCardMid">
          <div class="powerGrid powerGrid4">
            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T1", p.typeT1) %></div>
              <div class="powerVal"><%= fmt2(p.powerT1) %></div>
            </div>

            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T2", p.typeT2) %></div>
              <div class="powerVal"><%= fmt2(p.powerT2) %></div>
            </div>

            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T3", p.typeT3) %></div>
              <div class="powerVal"><%= fmt2(p.powerT3) %></div>
            </div>

            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T4", p.typeT4) %></div>
              <div class="powerVal"><%= fmt2(p.powerT4) %></div>
            </div>
          </div>
        </div>

        <div class="playerCardBottom">
          <div class="dateBlock">
            <div class="dateTop">
              <%= dt.dateStr %>
              <span class="dateSub muted"><%= dt.timeStr %></span>
            </div>
          </div>

          <div class="notesHint muted">
            <% if (p.notes && String(p.notes).trim().length > 0) { %>
              <button
                type="button"
                class="iconBtn notesOpenBtn"
                data-player-notes="<%= String(p.notes).trim() %>"
                data-player-nickname="<%= p.nickname %>">
                📝 <%= t("notes_short") %>
              </button>
            <% } else { %>
              &nbsp;
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- DESKTOP: table -->
  <div class="tableWrap desktopOnly">
    <table class="table tableCompact">
      <thead>
        <tr>
          <th class="colNick"><a class="thLink" href="<%= sortLink('nickname') %>"><%= t("nickname") %><%= sortArrow('nickname') %></a></th>
          <th class="colRole"><a class="thLink" href="<%= sortLink('role') %>"><%= t("role") %><%= sortArrow('role') %></a></th>

          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT1') %>">T1<%= sortArrow('powerT1') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT2') %>">T2<%= sortArrow('powerT2') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT3') %>">T3<%= sortArrow('powerT3') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT4') %>">T4<%= sortArrow('powerT4') %></a></th>

          <th class="colTotal"><a class="thLink" href="<%= sortLink('total') %>" title="<%= t('total_t1_t2_t3_only') %>"><%= t("total") %><%= sortArrow('total') %></a></th>
          <th class="colDate"><a class="thLink" href="<%= sortLink('updatedAt') %>"><%= t("date") %><%= sortArrow('updatedAt') %></a></th>

          <th class="colActions"><%= t("actions_short") %></th>
        </tr>
      </thead>

      <tbody>
        <% if (!players || players.length === 0) { %>
          <tr>
            <td colspan="9" class="muted"><%= t("no_players") %></td>
          </tr>
        <% } %>

        <% (players || []).forEach(p => {
          const dt = fmtDate(p.updatedAt);
        %>
          <tr title="<%= tooltipText(p) %>">
            <td class="colNick">
              <div class="cell2">
                <div class="cellTop"><b><%= p.nickname %></b></div>
                <div class="cellSub muted">
                  <% if (p.notes && String(p.notes).trim().length > 0) { %>
                    📝 <%= t("notes_short") %>
                  <% } else { %>
                    &nbsp;
                  <% } %>
                </div>
              </div>
            </td>

            <td class="colRole"><div class="cellSingle"><%= p.role || "-" %></div></td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT1) %></div>
                <div class="cellSub muted"><%= p.typeT1 ? translateTeamType(p.typeT1) : "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT2) %></div>
                <div class="cellSub muted"><%= p.typeT2 ? translateTeamType(p.typeT2) : "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT3) %></div>
                <div class="cellSub muted"><%= p.typeT3 ? translateTeamType(p.typeT3) : "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT4) %></div>
                <div class="cellSub muted"><%= p.typeT4 ? translateTeamType(p.typeT4) : "-" %></div>
              </div>
            </td>

            <td class="colTotal"><div class="cellSingle"><b><%= fmt2(p.total) %></b></div></td>

            <td class="colDate">
              <div class="cell2">
                <div class="cellTop"><%= dt.dateStr %></div>
                <div class="cellSub muted"><%= dt.timeStr %></div>
              </div>
            </td>

            <td class="colActions actions-cell">
              <div class="actionIcons table-actions">
                <a class="iconBtn" href="/potenze/<%= p._id %>/edit" title="<%= t('edit') %>" aria-label="<%= t('edit') %>: <%= p.nickname %>">✏️</a>
            <button type="button" class="iconBtn playerHistoryOpenBtn" data-player-id="<%= p._id %>" data-player-name="<%= p.nickname %>" title="<%= t('history_chart') %>" aria-label="<%= t('history_chart') %>: <%= p.nickname %>">📈</button>
                <% if (isAdmin) { %>
                  <form method="POST" action="/potenze/<%= p._id %>/delete" class="inlineForm" onsubmit="return confirm('<%= t('confirm_delete_player') %> <%= p.nickname %>?');">
                    <button class="iconBtn danger" type="submit" title="<%= t('delete') %>" aria-label="<%= t('delete') %>: <%= p.nickname %>">🗑️</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</section>


<div class="logModal" id="playerHistoryModal" hidden aria-hidden="true">
  <div class="logModalBackdrop" data-player-history-close="true"></div>
  <div class="logModalDialog logModalDialogWide" role="dialog" aria-modal="true" aria-labelledby="playerHistoryModalTitle">
    <div class="logModalHeader">
      <h3 id="playerHistoryModalTitle"><%= t("history_chart") %></h3>
      <button type="button" class="iconBtn" id="playerHistoryModalClose" aria-label="<%= t('close') %>">✖</button>
    </div>
    <div class="historyMeta muted" id="playerHistoryMeta"></div>
    <div class="historyScaleControls" id="historyScaleControls">
      <span class="historyScaleLabel"><%= t('period') %></span>
      <button type="button" class="historyScaleBtn" data-history-period="month" aria-pressed="false"><%= t('last_month') %></button>
      <button type="button" class="historyScaleBtn" data-history-period="3months" aria-pressed="false"><%= t('last_3_months') %></button>
      <button type="button" class="historyScaleBtn" data-history-period="6months" aria-pressed="false"><%= t('last_6_months') %></button>
      <button type="button" class="historyScaleBtn" data-history-period="year" aria-pressed="false"><%= t('last_year') %></button>
    </div>
    <div class="historyChartWrap">
      <canvas id="playerHistoryCanvas" height="320"></canvas>
      <div class="historyChartTooltip" id="playerHistoryTooltip" hidden></div>
    </div>
    <div class="historyLegend" id="playerHistoryLegend"></div>
    <div class="tableWrap historyTableWrap">
      <table class="table tableCompact">
        <thead>
          <tr>
            <th style="width: 28%;"><%= t("date") %></th>
            <th style="width: 18%;">T1</th>
            <th style="width: 18%;">T2</th>
            <th style="width: 18%;">T3</th>
            <th style="width: 18%;">T4</th>
          </tr>
        </thead>
        <tbody id="playerHistoryTableBody">
          <tr><td colspan="5" class="muted"><%= t("history_loading") %></td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="logModal" id="playerNotesModal" hidden aria-hidden="true">
  <div class="logModalBackdrop" data-player-notes-close="true"></div>
  <div class="logModalDialog" role="dialog" aria-modal="true" aria-labelledby="playerNotesModalTitle">
    <div class="logModalHeader">
      <h3 id="playerNotesModalTitle"><%= t("notes_details") %></h3>
      <button type="button" class="iconBtn" id="playerNotesTranslateBtn" aria-label="<%= t('translate_note') %>" title="<%= t('translate_note') %>">🌐</button>
      <button type="button" class="iconBtn" id="playerNotesModalClose" aria-label="<%= t('close') %>">✖</button>
    </div>
    <pre class="logModalBody" id="playerNotesModalBody"></pre>
  </div>
</div>

<script src="/js/power-history-series.js"></script>
<script>
  (function () {
    const modal = document.getElementById("playerNotesModal");
    const modalBody = document.getElementById("playerNotesModalBody");
    const closeBtn = document.getElementById("playerNotesModalClose");
    const translateBtn = document.getElementById("playerNotesTranslateBtn");
    const targetLang = "<%= currentLang %>";
    const translationPrefix = "<%= t('translation_prefix') %>";
    const translatingLabel = "<%= t('translating_note') %>";
    const translationError = "<%= t('translation_error') %>";
    const sameLanguageMsg = "<%= t('translation_same_language') %>";
    if (!modal || !modalBody || !closeBtn || !translateBtn) return;

    let originalText = "";
    let translatedText = "";
    let sourceLang = "";

    function closeModal() {
      modal.hidden = true;
      modalBody.textContent = "";
      modal.setAttribute("aria-hidden", "true");
      translateBtn.disabled = false;
      originalText = "";
      translatedText = "";
      sourceLang = "";
    }

    function openModal(text) {
      originalText = String(text || "").trim();
      translatedText = "";
      sourceLang = "";
      modalBody.textContent = originalText;
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
    }

    function buildBodyText() {
      if (!translatedText) return originalText;
      const langInfo = sourceLang ? `${sourceLang} → ${targetLang}` : targetLang;
      return `${originalText}\n\n────────\n${translationPrefix} (${langInfo}):\n${translatedText}`;
    }

    document.querySelectorAll("[data-player-notes]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const nickname = btn.getAttribute("data-player-nickname") || "-";
        const notes = btn.getAttribute("data-player-notes") || "-";
        openModal(`${nickname}\n\n${notes}`);
      });
    });

    closeBtn.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      closeModal();
    });

    modal.addEventListener("click", (event) => {
      const target = event.target;
      if (target && target.closest("[data-player-notes-close='true']")) {
        closeModal();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !modal.hidden) {
        closeModal();
      }
    });

    translateBtn.addEventListener("click", async () => {
      if (!originalText) return;
      translateBtn.disabled = true;
      modalBody.textContent = `${buildBodyText()}\n\n${translatingLabel}`;

      try {
        const resp = await fetch("/potenze/translate-note", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ text: originalText, targetLang })
        });
        const data = await resp.json();

        if (!resp.ok || !data?.ok) {
          modalBody.textContent = `${buildBodyText()}\n\n${translationError}`;
          return;
        }

        if (data.sameLanguage) {
          modalBody.textContent = `${buildBodyText()}\n\n${sameLanguageMsg}`;
          return;
        }

        translatedText = String(data.translatedText || "").trim();
        sourceLang = String(data.sourceLang || "").trim().toLowerCase();
        modalBody.textContent = buildBodyText();
      } catch (err) {
        modalBody.textContent = `${buildBodyText()}\n\n${translationError}`;
      } finally {
        translateBtn.disabled = false;
      }
    });

    const historyModal = document.getElementById("playerHistoryModal");
    const historyCloseBtn = document.getElementById("playerHistoryModalClose");
    const historyMeta = document.getElementById("playerHistoryMeta");
    const historyTableBody = document.getElementById("playerHistoryTableBody");
    const historyCanvas = document.getElementById("playerHistoryCanvas");
    const historyLegend = document.getElementById("playerHistoryLegend");
    const historyTooltip = document.getElementById("playerHistoryTooltip");

    const HISTORY_RETENTION_DAYS = <%- JSON.stringify(historyRetentionDays) %>;
    const HISTORY_LAST_YEAR_RANGE_TEXT = <%- JSON.stringify(t("history_period_range")) %>;
    const HISTORY_PERIODS = [
      { key: "month", days: 30, label: <%- JSON.stringify(t("last_month")) %>, noData: <%- JSON.stringify(t("no_history_last_month")) %> },
      { key: "3months", days: 90, label: <%- JSON.stringify(t("last_3_months")) %>, noData: <%- JSON.stringify(t("no_history_last_3_months")) %> },
      { key: "6months", days: 180, label: <%- JSON.stringify(t("last_6_months")) %>, noData: <%- JSON.stringify(t("no_history_last_6_months")) %> },
      { key: "year", days: HISTORY_RETENTION_DAYS, label: <%- JSON.stringify(t("last_year")) %>, noData: <%- JSON.stringify(t("no_history_last_year")) %> }
    ];
    const localeTag = <%- JSON.stringify(localeTag) %>;

    const seriesConfig = [
      { key: "t1", label: "T1", color: "#3a67ff" },
      { key: "t2", label: "T2", color: "#2bd576" },
      { key: "t3", label: "T3", color: "#ffaf45" },
      { key: "t4", label: "T4", color: "#ff5c7a" },
      { key: "total", label: "TOT", color: "#b86bff" }
    ];
    const seriesVisibility = Object.fromEntries(seriesConfig.map((serie) => [serie.key, serie.key !== "total"]));
    let currentChartPoints = [];
    let currentDisplayChartPoints = [];
    let currentChartLayout = null;
    let currentHistoryPeriod = "year";
    let currentHistoryRows = [];
    let currentHistoryBaseline = null;
    let currentPlayerName = "";

    const formatPointValue = (value) => Number(value || 0).toLocaleString(localeTag, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const formatTableValue = (value) => Number(value || 0).toLocaleString(localeTag, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const monthYearFormatter = new Intl.DateTimeFormat(localeTag, { month: "short", year: "numeric", timeZone: "UTC" });
    const dayMonthFormatter = new Intl.DateTimeFormat(localeTag, { day: "2-digit", month: "short", timeZone: "UTC" });
    const fullDateFormatter = new Intl.DateTimeFormat(localeTag, { day: "2-digit", month: "short", year: "numeric", timeZone: "UTC" });
    const numericDateFormatter = new Intl.DateTimeFormat(localeTag, { day: "2-digit", month: "2-digit", year: "numeric", timeZone: "UTC" });

    function escapeHtml(value) {
      return String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function parseIsoDayUTC(isoDay) {
      const dateObj = new Date(`${isoDay}T00:00:00Z`);
      return Number.isNaN(dateObj.getTime()) ? null : dateObj;
    }

    function formatMonthYear(isoDay) {
      const dateObj = parseIsoDayUTC(isoDay);
      return dateObj ? monthYearFormatter.format(dateObj) : String(isoDay || "");
    }

    function formatFullDate(isoDay) {
      const dateObj = parseIsoDayUTC(isoDay);
      return dateObj ? numericDateFormatter.format(dateObj) : String(isoDay || "");
    }

    function formatDayMonth(isoDay) {
      const dateObj = parseIsoDayUTC(isoDay);
      return dateObj ? dayMonthFormatter.format(dateObj) : String(isoDay || "");
    }

    function formatRangeDate(isoDay) {
      const dateObj = parseIsoDayUTC(isoDay);
      return dateObj ? fullDateFormatter.format(dateObj) : String(isoDay || "");
    }

    function getCurrentPeriod() {
      return HISTORY_PERIODS.find((period) => period.key === currentHistoryPeriod) || HISTORY_PERIODS[HISTORY_PERIODS.length - 1];
    }

    function getHistoryRangeLabel(points) {
      const period = getCurrentPeriod();
      if (!Array.isArray(points) || points.length === 0) return period.label;
      const start = formatRangeDate(points[0].date);
      const end = formatRangeDate(points[points.length - 1].date);
      return HISTORY_LAST_YEAR_RANGE_TEXT
        .replace("{period}", period.label)
        .replace("{range}", `${start} - ${end}`);
    }

    function addDaysUTC(dateObj, days) {
      return new Date(Date.UTC(dateObj.getUTCFullYear(), dateObj.getUTCMonth(), dateObj.getUTCDate() + days, 0, 0, 0, 0));
    }

    function addMonthsUTC(dateObj, months) {
      return new Date(Date.UTC(dateObj.getUTCFullYear(), dateObj.getUTCMonth() + months, 1, 0, 0, 0, 0));
    }

    function getXAxisTicks(points) {
      if (!Array.isArray(points) || points.length === 0) return new Map();

      const ticks = new Map();
      const period = getCurrentPeriod();
      const availableDays = new Set(points.map((point) => point?.date).filter(Boolean));
      const startDate = parseIsoDayUTC(points[0].date);
      const endDate = parseIsoDayUTC(points[points.length - 1].date);
      if (!startDate || !endDate) return ticks;

      const monthKeyForIsoDay = (isoDay) => {
        const dateObj = parseIsoDayUTC(isoDay);
        return dateObj ? `${dateObj.getUTCFullYear()}-${dateObj.getUTCMonth()}` : String(isoDay || "");
      };
      const hasTickInSameMonth = (isoDay) => {
        const monthKey = monthKeyForIsoDay(isoDay);
        return Array.from(ticks.keys()).some((tickIsoDay) => monthKeyForIsoDay(tickIsoDay) === monthKey);
      };
      const addTick = (dateObj, labelFormatter, options = {}) => {
        const isoDay = toIsoDayUTC(dateObj);
        if (!availableDays.has(isoDay)) return;
        const label = labelFormatter(isoDay);
        const previousLabel = Array.from(ticks.values()).at(-1);
        if (options.skipDuplicateMonth && hasTickInSameMonth(isoDay)) return;
        if (previousLabel === label) return;
        ticks.set(isoDay, label);
      };

      if (period.key === "month") {
        [0, 7, 14, 21, 28].forEach((offset) => {
          const tickDate = addDaysUTC(startDate, offset);
          if (tickDate <= endDate) addTick(tickDate, formatDayMonth);
        });
        addTick(endDate, formatDayMonth);
        return ticks;
      }

      const firstMonthTick = new Date(Date.UTC(startDate.getUTCFullYear(), startDate.getUTCMonth(), 1, 0, 0, 0, 0));
      for (let tickDate = firstMonthTick; tickDate <= endDate; tickDate = addMonthsUTC(tickDate, 1)) {
        if (tickDate < startDate) {
          addTick(startDate, period.key === "3months" ? formatDayMonth : formatMonthYear);
          continue;
        }
        addTick(tickDate, period.key === "3months" ? formatMonthYear : formatMonthYear);
      }
      addTick(endDate, period.key === "3months" ? formatDayMonth : formatMonthYear, { skipDuplicateMonth: true });

      return ticks;
    }

    const hasRealEntry = (point) => point?._real === true;

    function closeHistoryModal() {
      if (!historyModal) return;
      historyModal.hidden = true;
      historyModal.setAttribute("aria-hidden", "true");
      hideHistoryTooltip();
    }

    function openHistoryModal() {
      if (!historyModal) return;
      historyModal.hidden = false;
      historyModal.setAttribute("aria-hidden", "false");
    }

    function getVisibleSeries() {
      return seriesConfig.filter((serie) => seriesVisibility[serie.key] !== false);
    }

    function resizeHistoryCanvas() {
      if (!historyCanvas) return;
      const cssWidth = Math.max(320, Math.floor(historyCanvas.clientWidth || 980));
      const cssHeight = 320;

      if (historyCanvas.width !== cssWidth || historyCanvas.height !== cssHeight) {
        historyCanvas.width = cssWidth;
        historyCanvas.height = cssHeight;
      }
    }

    function drawHistoryChart(points) {
      if (!historyCanvas) return;
      currentDisplayChartPoints = points;
      resizeHistoryCanvas();
      const ctx = historyCanvas.getContext("2d");
      const w = historyCanvas.width;
      const h = historyCanvas.height;
      const pad = { l: 56, r: 78, t: 16, b: 74 };
      const chartW = w - pad.l - pad.r;
      const chartH = h - pad.t - pad.b;
      currentChartLayout = { pad, chartW, chartH, width: w, height: h };
      const visibleSeries = getVisibleSeries();

      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = "#0d1424";
      ctx.fillRect(0, 0, w, h);

      if (!points || points.length === 0) {
        ctx.fillStyle = "#a9b6d3";
        ctx.font = "11px sans-serif";
        ctx.fillText(getCurrentPeriod().noData, 20, 26);
        return;
      }

      const numericValues = points.flatMap((point) =>
        visibleSeries
          .map((serie) => point[serie.key])
          .filter((value) => Number.isFinite(value))
      );
      const maxY = Math.max(1, ...(numericValues.length ? numericValues : [0]));
      const minY = 0;

      ctx.strokeStyle = "rgba(169,182,211,.25)";
      ctx.lineWidth = 1;
      for (let i = 0; i <= 5; i++) {
        const yy = pad.t + (chartH * i) / 5;
        ctx.beginPath();
        ctx.moveTo(pad.l, yy);
        ctx.lineTo(w - pad.r, yy);
        ctx.stroke();

        const val = (maxY - ((maxY - minY) * i) / 5).toFixed(0);
        ctx.fillStyle = "#a9b6d3";
        ctx.font = "11px sans-serif";
        ctx.fillText(val, 4, yy + 4);
      }

      const xForIndex = (i) => pad.l + (points.length === 1 ? chartW / 2 : (chartW * i) / (points.length - 1));
      const yForValue = (v) => pad.t + chartH - ((v - minY) / (maxY - minY)) * chartH;

      points.forEach((point, i) => {
        if (!hasRealEntry(point)) return;
        const x = xForIndex(i);
        ctx.save();
        ctx.setLineDash([4, 4]);
        ctx.strokeStyle = "rgba(184,107,255,.4)";
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(x, pad.t);
        ctx.lineTo(x, pad.t + chartH);
        ctx.stroke();
        ctx.restore();
      });

      const xAxisTicks = getXAxisTicks(points);
      points.forEach((p, i) => {
        const tickLabel = xAxisTicks.get(p.date);
        if (!tickLabel) return;
        const x = xForIndex(i);
        ctx.save();
        ctx.translate(x, h - 26);
        ctx.rotate(-Math.PI / 6);
        ctx.fillStyle = hasRealEntry(p) ? "#d4dcf0" : "#a9b6d3";
        ctx.font = "11px sans-serif";
        ctx.fillText(tickLabel, 0, 0);
        ctx.restore();
      });

      visibleSeries.forEach((serie) => {
        ctx.beginPath();
        ctx.lineWidth = 2;
        ctx.strokeStyle = serie.color;
        ctx.lineJoin = "round";
        ctx.lineCap = "round";
        let hasPath = false;
        points.forEach((point, i) => {
          const rawValue = point[serie.key];
          if (!Number.isFinite(rawValue)) {
            hasPath = false;
            return;
          }
          const x = xForIndex(i);
          const y = yForValue(rawValue);
          if (!hasPath) {
            ctx.moveTo(x, y);
            hasPath = true;
          } else {
            ctx.lineTo(x, y);
          }
        });
        ctx.stroke();

        let lastPoint = null;
        for (let i = points.length - 1; i >= 0; i--) {
          const point = points[i];
          const rawValue = point[serie.key];
          if (!Number.isFinite(rawValue)) continue;
          lastPoint = { index: i, value: rawValue };
          break;
        }
        if (!lastPoint) return;

        const labelX = Math.min(w - pad.r + 6, xForIndex(lastPoint.index) + 8);
        const labelY = yForValue(lastPoint.value);
        ctx.fillStyle = serie.color;
        ctx.font = "bold 11px sans-serif";
        ctx.textBaseline = "middle";
        ctx.fillText(`${serie.label} ${formatPointValue(lastPoint.value)}`, labelX, labelY);
      });
    }

    function hideHistoryTooltip() {
      if (!historyTooltip) return;
      historyTooltip.hidden = true;
      historyTooltip.innerHTML = "";
    }

    function showHistoryTooltip(event) {
      if (!historyTooltip || !historyCanvas || !currentChartLayout || !currentDisplayChartPoints.length) return;
      const rect = historyCanvas.getBoundingClientRect();
      const cssX = event.clientX - rect.left;
      const canvasX = cssX * (historyCanvas.width / rect.width);
      const { pad, chartW } = currentChartLayout;
      if (canvasX < pad.l || canvasX > historyCanvas.width - pad.r) {
        hideHistoryTooltip();
        return;
      }

      const lastIndex = currentDisplayChartPoints.length - 1;
      const rawIndex = lastIndex === 0 ? 0 : Math.round(((canvasX - pad.l) / chartW) * lastIndex);
      const pointIndex = Math.min(lastIndex, Math.max(0, rawIndex));
      const point = currentDisplayChartPoints[pointIndex];
      if (!point) {
        hideHistoryTooltip();
        return;
      }

      const tooltipDate = formatFullDate(point.date);
      const rows = [`<strong>${tooltipDate}</strong>`];
      getVisibleSeries().forEach((serie) => {
        rows.push(`<span style="color:${serie.color}">${serie.label}: ${formatPointValue(point[serie.key])}</span>`);
      });
      historyTooltip.innerHTML = rows.join("<br>");
      historyTooltip.hidden = false;
      historyTooltip.style.left = `${Math.min(rect.width - 180, Math.max(8, cssX + 12))}px`;
      historyTooltip.style.top = `${Math.max(8, event.clientY - rect.top - 12)}px`;
    }

    function renderLegend() {
      if (!historyLegend) return;
      historyLegend.innerHTML = seriesConfig
        .map((serie) => {
          const inactiveClass = seriesVisibility[serie.key] === false ? " legendItemOff" : "";
          return `<button type="button" class="legendItem${inactiveClass}" data-series-key="${serie.key}" aria-pressed="${seriesVisibility[serie.key] !== false}"><span class="legendDot" style="background:${serie.color}"></span>${serie.label}</button>`;
        })
        .join("");

      historyLegend.querySelectorAll("[data-series-key]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.getAttribute("data-series-key");
          if (!key || !(key in seriesVisibility)) return;
          seriesVisibility[key] = !seriesVisibility[key];
          renderLegend();
          drawHistoryChart(currentChartPoints);
        });
      });
    }

    function updateHistoryControls() {
      const controls = document.getElementById("historyScaleControls");
      if (!controls) return;
      controls.querySelectorAll("[data-history-period]").forEach((item) => {
        const active = item.getAttribute("data-history-period") === currentHistoryPeriod;
        item.classList.toggle("isActive", active);
        item.setAttribute("aria-pressed", active ? "true" : "false");
      });
    }

    function setupScaleControls() {
      const controls = document.getElementById("historyScaleControls");
      if (!controls) return;
      controls.querySelectorAll("[data-history-period]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const selected = btn.getAttribute("data-history-period");
          if (!HISTORY_PERIODS.some((period) => period.key === selected)) return;
          currentHistoryPeriod = selected;
          updateHistoryView();
        });
      });
    }

    function toIsoDayUTC(dateObj) {
      const y = dateObj.getUTCFullYear();
      const m = String(dateObj.getUTCMonth() + 1).padStart(2, "0");
      const d = String(dateObj.getUTCDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    const { findPreviousRowForPeriod, buildLastDaysForChart } = window.LWPowerHistorySeries;

    function getPeriodStartIso(period) {
      const now = new Date();
      return toIsoDayUTC(new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() - period.days, 0, 0, 0, 0)));
    }

    function chooseDefaultHistoryPeriod(rows) {
      if (!Array.isArray(rows) || rows.length === 0) return "month";
      const oldest = rows.reduce((min, row) => row?.date && (!min || String(row.date) < min) ? String(row.date) : min, "");
      if (!oldest) return "month";
      for (const period of HISTORY_PERIODS) {
        if (oldest >= getPeriodStartIso(period)) return period.key;
      }
      return "year";
    }

    function buildFilledTableRows(rows) {
      const sortedAsc = [...(rows || [])].sort((a, b) => String(a.date || "").localeCompare(String(b.date || "")));
      const filledAscRows = [];
      let previousSnapshot = null;
      sortedAsc.forEach((row) => {
        const current = {
          date: String(row.date || ""),
          t1: Number(row.t1),
          t2: Number(row.t2),
          t3: Number(row.t3),
          t4: Number(row.t4)
        };

        ["t1", "t2", "t3", "t4"].forEach((key) => {
          if (Number.isFinite(current[key])) return;
          current[key] = previousSnapshot ? Number(previousSnapshot[key] || 0) : 0;
        });
        current.total = Math.round((current.t1 + current.t2 + current.t3 + current.t4) * 100) / 100;

        if (previousSnapshot) {
          current.growth = {};
          ["t1", "t2", "t3", "t4", "total"].forEach((key) => {
            const prevVal = Number(previousSnapshot[key] || 0);
            const currVal = Number(current[key] || 0);
            if (!Number.isFinite(prevVal) || !Number.isFinite(currVal) || prevVal === 0) {
              current.growth[key] = null;
              return;
            }
            const pct = ((currVal - prevVal) / prevVal) * 100;
            current.growth[key] = Number.isFinite(pct) ? pct : null;
          });
        } else {
          current.growth = { t1: null, t2: null, t3: null, t4: null, total: null };
        }

        filledAscRows.push(current);
        previousSnapshot = current;
      });
      return filledAscRows;
    }

    function updateHistoryView() {
      const period = getCurrentPeriod();
      const periodStart = getPeriodStartIso(period);
      const rowsInPeriod = currentHistoryRows.filter((row) => String(row?.date || "") >= periodStart);
      const previousRow = findPreviousRowForPeriod(currentHistoryRows, periodStart, currentHistoryBaseline);
      const chartRows = buildLastDaysForChart(rowsInPeriod, period.days, previousRow);
      currentChartPoints = chartRows;
      historyMeta.innerHTML = `<strong>${escapeHtml(currentPlayerName)}</strong> · ${escapeHtml(getHistoryRangeLabel(chartRows))}`;
      updateHistoryControls();
      if (!rowsInPeriod.length) {
        historyTableBody.innerHTML = `<tr><td colspan="5" class="muted">${period.noData}</td></tr>`;
        drawHistoryChart(chartRows);
        return;
      }

      const displayRows = buildFilledTableRows(rowsInPeriod).reverse();
      const renderCell = (value, growthPct) => {
        const valueHtml = formatTableValue(value);
        if (!Number.isFinite(growthPct) || growthPct === 0) return valueHtml;
        const growthSign = growthPct > 0 ? "+" : "-";
        const growthClass = growthPct > 0 ? "historyGrowth" : "historyGrowth historyGrowthNegative";
        const growthText = `(${growthSign}${Math.abs(growthPct).toFixed(2)}%)`;
        return `${valueHtml} <span class="${growthClass}">${growthText}</span>`;
      };

      historyTableBody.innerHTML = displayRows
        .map((row) => `<tr><td class="historyDateCell">${row.date}</td><td>${renderCell(row.t1, row.growth?.t1)}</td><td>${renderCell(row.t2, row.growth?.t2)}</td><td>${renderCell(row.t3, row.growth?.t3)}</td><td>${renderCell(row.t4, row.growth?.t4)}</td></tr>`)
        .join("");

      drawHistoryChart(chartRows);
    }

    async function openPlayerHistory(playerId, playerName) {
      seriesConfig.forEach((serie) => {
        seriesVisibility[serie.key] = serie.key !== "total";
      });
      seriesVisibility.t4 = false;
      currentChartPoints = [];
      currentHistoryRows = [];
      currentHistoryBaseline = null;
      currentPlayerName = playerName;
      currentHistoryPeriod = "year";
      updateHistoryControls();
      openHistoryModal();
      historyMeta.textContent = `${playerName} · ${getCurrentPeriod().label}`;
      historyTableBody.innerHTML = `<tr><td colspan="5" class="muted"><%= t("history_loading") %></td></tr>`;
      renderLegend();
      drawHistoryChart([]);

      try {
        const resp = await fetch(`/potenze/${playerId}/history-data?days=${HISTORY_RETENTION_DAYS}`);
        const data = await resp.json();
        if (!resp.ok || !data?.ok) throw new Error("history_error");

        const rows = data.history || [];
        currentHistoryRows = rows;
        currentHistoryBaseline = data.previous || null;
        currentHistoryPeriod = chooseDefaultHistoryPeriod(rows);
        const hasT4Entries = rows.some((row) => Number(row?.t4 || 0) > 0);
        seriesVisibility.t4 = hasT4Entries;
        renderLegend();
        updateHistoryView();
      } catch (err) {
        historyTableBody.innerHTML = `<tr><td colspan="5" class="muted"><%= t("err_internal") %></td></tr>`;
      }
    }

    setupScaleControls();

    if (historyCanvas) {
      historyCanvas.addEventListener("mousemove", showHistoryTooltip);
      historyCanvas.addEventListener("mouseleave", hideHistoryTooltip);
    }

    window.addEventListener("resize", () => {
      if (historyModal && !historyModal.hidden) {
        drawHistoryChart(currentChartPoints);
      }
    });

    document.querySelectorAll(".playerHistoryOpenBtn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const playerId = btn.getAttribute("data-player-id");
        const playerName = btn.getAttribute("data-player-name") || "-";
        if (!playerId) return;
        openPlayerHistory(playerId, playerName);
      });
    });

    if (historyCloseBtn) {
      historyCloseBtn.addEventListener("click", (event) => {
        event.preventDefault();
        closeHistoryModal();
      });
    }

    if (historyModal) {
      historyModal.addEventListener("click", (event) => {
        const target = event.target;
        if (target && target.closest("[data-player-history-close='true']")) {
          closeHistoryModal();
        }
      });
    }

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && historyModal && !historyModal.hidden) {
        closeHistoryModal();
      }
    });

  })();
</script>

<%- include("../partials/footer") %>
