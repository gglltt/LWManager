<%- include("../partials/header") %>

<%
  function fmt2(v) {
    if (v === null || v === undefined || v === "") return "-";
    const n = Number(v);
    if (Number.isNaN(n)) return "-";
    return n.toLocaleString(localeTag, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function fmtDate(d) {
    if (!d) return { dateStr: "-", timeStr: "-" };
    const dt = new Date(d);
    if (Number.isNaN(dt.getTime())) return { dateStr: "-", timeStr: "-" };
    const dateStr = dt.toLocaleDateString(localeTag);
    const timeStr = dt.toLocaleTimeString(localeTag, { hour: "2-digit", minute: "2-digit" });
    return { dateStr, timeStr };
  }

  function sortLink(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";

    let nextDir = "asc";
    if (currentSort === field && currentDir === "asc") nextDir = "desc";
    if (currentSort === field && currentDir === "desc") nextDir = "asc";

    const params = new URLSearchParams({ sort: field, dir: nextDir });
    if (q && String(q).trim().length > 0) params.set("q", String(q).trim());
    return `/potenze?${params.toString()}`;
  }

  function sortArrow(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";
    if (currentSort !== field) return "";
    return currentDir === "asc" ? " ▲" : " ▼";
  }

  function tooltipText(p) {
    const parts = [];
    if (p.notes && String(p.notes).trim().length > 0) parts.push(`${t("notes_optional")}: ${String(p.notes).trim()}`);
    parts.push(`${t("updated_at")}: ${p.updatedAt ? new Date(p.updatedAt).toLocaleString(localeTag) : "-"}`);
    return parts.join(" | ");
  }

  function labelType(tLabel, tType) {
    const type = tType && String(tType).trim().length > 0 ? String(tType).trim() : "-";
    return `${tLabel}:${type}`;
  }
%>

<section class="card cardWide">
  <div class="pageHeader">
    <div>
      <h1><%= t("powers_title") %></h1>
      <p class="muted"><%= t("powers_mobile_desc") %></p>
      <p><strong><%= t("players_registered") %>: <%= playerCount %></strong></p>
      <p class="muted"><%= t("current_role") %>: <b><%= isAdmin ? t("admin") : t("standard") %></b></p>
    </div>

    <div class="pageHeaderActions">
      <a class="button secondary" href="/dashboard">← <%= t("back_dashboard") %></a>
      <% if (isAdmin) { %>
        <a class="button secondary" href="/potenze/export">⬇️ Export Excel</a>
      <% } else { %>
        <span class="muted" title="<%= t('export_requires_admin_pin') %>"><%= t("export_admin_only") %></span>
      <% } %>
      <a class="button" href="/potenze/new"><%= t("new_player_button") %></a>
    </div>
  </div>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form method="GET" action="/potenze" class="filterBar">
    <input type="hidden" name="sort" value="<%= sort %>" />
    <input type="hidden" name="dir" value="<%= dir %>" />
    <input
      type="text"
      name="q"
      value="<%= q || "" %>"
      placeholder="<%= t('nickname_filter_placeholder') %>"
      class="filterInput"
    />
    <button type="submit" class="button"><%= t("search") %></button>
    <% if (q && String(q).trim().length > 0) { %>
      <a class="button secondary" href="/potenze?sort=<%= encodeURIComponent(sort) %>&dir=<%= encodeURIComponent(dir) %>" title="<%= t('remove_filter') %>">✕</a>
    <% } %>
  </form>

  <!-- MOBILE: quick sort bar -->
  <div class="sortBar">
    <span class="muted"><%= t("sort_by") %>:</span>
    <a class="sortPill" href="<%= sortLink('nickname') %>">Nick<%= sortArrow('nickname') %></a>
    <a class="sortPill" href="<%= sortLink('powerT1') %>">T1<%= sortArrow('powerT1') %></a>
    <a class="sortPill" href="<%= sortLink('total') %>">Tot<%= sortArrow('total') %></a>
    <a class="sortPill" href="<%= sortLink('updatedAt') %>">Data<%= sortArrow('updatedAt') %></a>
  </div>

  <!-- MOBILE: cards -->
  <div class="playerCards">
    <% if (!players || players.length === 0) { %>
      <div class="muted"><%= t("no_players") %></div>
    <% } %>

    <% (players || []).forEach(p => { 
      const dt = fmtDate(p.updatedAt);
    %>
      <div class="playerCard" title="<%= tooltipText(p) %>">
        <div class="playerCardTop">
          <div class="playerTitle">
            <div class="playerTitleLine">
              <span class="playerNick"><%= p.nickname %></span>
              <span class="playerMeta muted">
                <span>- R<%= p.role || "-" %></span>
                <span>- <%= fmt2(p.total) %></span>
              </span>
            </div>
          </div>

          <div class="playerActions">
            <a class="iconBtn" href="/potenze/<%= p._id %>/edit" title="<%= t('edit') %>">✏️</a>
            <% if (isAdmin) { %>
              <form method="POST" action="/potenze/<%= p._id %>/delete" class="inlineForm" onsubmit="return confirm('<%= t('confirm_delete_player') %> <%= p.nickname %>?');">
                <button class="iconBtn danger" type="submit" title="<%= t('delete') %>">🗑️</button>
              </form>
            <% } %>
          </div>
        </div>

        <div class="playerCardMid">
          <div class="powerGrid powerGrid4">
            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T1", p.typeT1) %></div>
              <div class="powerVal"><%= fmt2(p.powerT1) %></div>
            </div>

            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T2", p.typeT2) %></div>
              <div class="powerVal"><%= fmt2(p.powerT2) %></div>
            </div>

            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T3", p.typeT3) %></div>
              <div class="powerVal"><%= fmt2(p.powerT3) %></div>
            </div>

            <div class="powerCell">
              <div class="powerHead muted"><%= labelType("T4", p.typeT4) %></div>
              <div class="powerVal"><%= fmt2(p.powerT4) %></div>
            </div>
          </div>
        </div>

        <div class="playerCardBottom">
          <div class="dateBlock">
            <div class="dateTop">
              <%= dt.dateStr %>
              <span class="dateSub muted"><%= dt.timeStr %></span>
            </div>
          </div>

          <div class="notesHint muted">
            <% if (p.notes && String(p.notes).trim().length > 0) { %>
              📝 <%= t("notes_short") %>
            <% } else { %>
              &nbsp;
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- DESKTOP: table -->
  <div class="tableWrap desktopOnly">
    <table class="table tableCompact">
      <thead>
        <tr>
          <th class="colNick"><a class="thLink" href="<%= sortLink('nickname') %>">Nick<%= sortArrow('nickname') %></a></th>
          <th class="colRole"><a class="thLink" href="<%= sortLink('role') %>"><%= sortArrow('role') %></a></th>

          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT1') %>">T1<%= sortArrow('powerT1') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT2') %>">T2<%= sortArrow('powerT2') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT3') %>">T3<%= sortArrow('powerT3') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT4') %>">T4<%= sortArrow('powerT4') %></a></th>

          <th class="colTotal"><a class="thLink" href="<%= sortLink('total') %>">Tot<%= sortArrow('total') %></a></th>
          <th class="colDate"><a class="thLink" href="<%= sortLink('updatedAt') %>">Data<%= sortArrow('updatedAt') %></a></th>

          <th class="colActions"><%= t("actions_short") %></th>
        </tr>
      </thead>

      <tbody>
        <% if (!players || players.length === 0) { %>
          <tr>
            <td colspan="9" class="muted"><%= t("no_players") %></td>
          </tr>
        <% } %>

        <% (players || []).forEach(p => {
          const dt = fmtDate(p.updatedAt);
        %>
          <tr title="<%= tooltipText(p) %>">
            <td class="colNick">
              <div class="cell2">
                <div class="cellTop"><b><%= p.nickname %></b></div>
                <div class="cellSub muted">
                  <% if (p.notes && String(p.notes).trim().length > 0) { %>
                    📝 <%= t("notes_short") %>
                  <% } else { %>
                    &nbsp;
                  <% } %>
                </div>
              </div>
            </td>

            <td class="colRole"><div class="cellSingle"><%= p.role || "-" %></div></td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT1) %></div>
                <div class="cellSub muted"><%= p.typeT1 || "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT2) %></div>
                <div class="cellSub muted"><%= p.typeT2 || "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT3) %></div>
                <div class="cellSub muted"><%= p.typeT3 || "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT4) %></div>
                <div class="cellSub muted"><%= p.typeT4 || "-" %></div>
              </div>
            </td>

            <td class="colTotal"><div class="cellSingle"><b><%= fmt2(p.total) %></b></div></td>

            <td class="colDate">
              <div class="cell2">
                <div class="cellTop"><%= dt.dateStr %></div>
                <div class="cellSub muted"><%= dt.timeStr %></div>
              </div>
            </td>

            <td class="colActions">
              <div class="actionIcons">
                <a class="iconBtn" href="/potenze/<%= p._id %>/edit" title="<%= t('edit') %>">✏️</a>
                <% if (isAdmin) { %>
                  <form method="POST" action="/potenze/<%= p._id %>/delete" class="inlineForm" onsubmit="return confirm('<%= t('confirm_delete_player') %> <%= p.nickname %>?');">
                    <button class="iconBtn danger" type="submit" title="<%= t('delete') %>">🗑️</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (!isAdmin) { %>
    <p class="muted" style="margin-top: 12px;">
      <%= t("standard_mode_hint") %>
    </p>
  <% } %>
</section>

<%- include("../partials/footer") %>
