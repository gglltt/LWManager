<%- include("../partials/header") %>

<%
  function fmt2(v) {
    if (v === null || v === undefined || v === "") return "-";
    const n = Number(v);
    if (Number.isNaN(n)) return "-";
    return n.toLocaleString("it-IT", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function fmtDate(d) {
    if (!d) return "-";
    const dt = new Date(d);
    if (Number.isNaN(dt.getTime())) return "-";
    const dateStr = dt.toLocaleDateString("it-IT");
    const timeStr = dt.toLocaleTimeString("it-IT", { hour: "2-digit", minute: "2-digit" });
    return { dateStr, timeStr };
  }

  function sortLink(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";

    let nextDir = "asc";
    if (currentSort === field && currentDir === "asc") nextDir = "desc";
    if (currentSort === field && currentDir === "desc") nextDir = "asc";

    return `/potenze?sort=${encodeURIComponent(field)}&dir=${encodeURIComponent(nextDir)}`;
  }

  function sortArrow(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";
    if (currentSort !== field) return "";
    return currentDir === "asc" ? " ▲" : " ▼";
  }

  function tooltipText(p) {
    const parts = [];
    if (p.notes && String(p.notes).trim().length > 0) parts.push(`Note: ${String(p.notes).trim()}`);
    parts.push(`Aggiornato: ${p.updatedAt ? new Date(p.updatedAt).toLocaleString("it-IT") : "-"}`);
    return parts.join(" | ");
  }
%>

<section class="card cardWide">
  <div class="pageHeader">
    <div>
      <h1>Potenze</h1>
      <p class="muted">Vista compatta per mobile. Note disponibili nel tooltip sul nickname.</p>
    </div>

    <div class="pageHeaderActions">
      <a class="button secondary" href="/dashboard">← Dashboard</a>

      <% if (isAdmin) { %>
        <a class="button" href="/potenze/new">+ Nuovo</a>
      <% } %>
    </div>
  </div>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <div class="tableWrap">
    <table class="table tableCompact">
      <thead>
        <tr>
          <th class="colNick"><a class="thLink" href="<%= sortLink('nickname') %>">Nick<%= sortArrow('nickname') %></a></th>
          <th class="colRole"><a class="thLink" href="<%= sortLink('role') %>">R<%= sortArrow('role') %></a></th>

          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT1') %>">T1<%= sortArrow('powerT1') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT2') %>">T2<%= sortArrow('powerT2') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT3') %>">T3<%= sortArrow('powerT3') %></a></th>
          <th class="colTier"><a class="thLink" href="<%= sortLink('powerT4') %>">T4<%= sortArrow('powerT4') %></a></th>

          <th class="colTotal"><a class="thLink" href="<%= sortLink('total') %>">Tot<%= sortArrow('total') %></a></th>
          <th class="colDate"><a class="thLink" href="<%= sortLink('updatedAt') %>">Data<%= sortArrow('updatedAt') %></a></th>

          <% if (isAdmin) { %>
            <th class="colActions">Az</th>
          <% } %>
        </tr>
      </thead>

      <tbody>
        <% if (!players || players.length === 0) { %>
          <tr>
            <td colspan="<%= isAdmin ? 9 : 8 %>" class="muted">Nessun giocatore inserito.</td>
          </tr>
        <% } %>

        <% players.forEach(p => { 
             const dt = fmtDate(p.updatedAt);
        %>
          <tr title="<%= tooltipText(p) %>">
            <td class="colNick">
              <div class="cell2">
                <div class="cellTop">
                  <b title="<%= tooltipText(p) %>"><%= p.nickname %></b>
                </div>
                <div class="cellSub muted">
                  <% if (p.notes && String(p.notes).trim().length > 0) { %>
                    📝 note
                  <% } else { %>
                    &nbsp;
                  <% } %>
                </div>
              </div>
            </td>

            <td class="colRole">
              <div class="cellSingle"><%= p.role || "-" %></div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT1) %></div>
                <div class="cellSub muted"><%= p.typeT1 || "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT2) %></div>
                <div class="cellSub muted"><%= p.typeT2 || "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT3) %></div>
                <div class="cellSub muted"><%= p.typeT3 || "-" %></div>
              </div>
            </td>

            <td class="colTier">
              <div class="cell2">
                <div class="cellTop"><%= fmt2(p.powerT4) %></div>
                <div class="cellSub muted"><%= p.typeT4 || "-" %></div>
              </div>
            </td>

            <td class="colTotal">
              <div class="cellSingle"><b><%= fmt2(p.total) %></b></div>
            </td>

            <td class="colDate">
              <div class="cell2">
                <div class="cellTop"><%= dt.dateStr %></div>
                <div class="cellSub muted"><%= dt.timeStr %></div>
              </div>
            </td>

            <% if (isAdmin) { %>
              <td class="colActions">
                <div class="actionIcons">
                  <a class="iconBtn" href="/potenze/<%= p._id %>/edit" title="Modifica">✏️</a>
                  <form method="POST" action="/potenze/<%= p._id %>/delete" class="inlineForm" onsubmit="return confirm('Confermi la cancellazione di <%= p.nickname %>?');">
                    <button class="iconBtn danger" type="submit" title="Elimina">🗑️</button>
                  </form>
                </div>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (!isAdmin) { %>
    <p class="muted" style="margin-top: 12px;">
      Solo gli utenti di livello 5 possono inserire, modificare o cancellare giocatori.
    </p>
  <% } %>
</section>

<%- include("../partials/footer") %>