  <div class="logModalDialog logModalDialogWide" role="dialog" aria-modal="true" aria-labelledby="playerHistoryModalTitle">
    <div class="logModalHeader">
      <h3 id="playerHistoryModalTitle"><%= t("history_chart") %></h3>
      <button type="button" class="iconBtn" id="playerHistoryModalClose" aria-label="<%= t('close') %>">✖</button>
    </div>
    <div class="historyMeta muted" id="playerHistoryMeta"></div>
    <div class="historyScaleControls" id="historyScaleControls">
      <span class="historyScaleLabel"><%= t('scale') %></span>
      <button type="button" class="historyScaleBtn isActive" data-history-scale="daily" aria-pressed="true"><%= t('daily') %></button>
      <button type="button" class="historyScaleBtn" data-history-scale="weekly" aria-pressed="false"><%= t('weekly') %></button>
      <span class="historyScaleLabel historyPeriodLabel"><%= t('period') %></span>
      <button type="button" class="historyScaleBtn" data-history-period="month" aria-pressed="false"><%= t('last_month') %></button>
      <button type="button" class="historyScaleBtn" data-history-period="3months" aria-pressed="false"><%= t('last_3_months') %></button>
      <button type="button" class="historyScaleBtn" data-history-period="6months" aria-pressed="false"><%= t('last_6_months') %></button>
      <button type="button" class="historyScaleBtn" data-history-period="year" aria-pressed="false"><%= t('last_year') %></button>
