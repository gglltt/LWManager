<div class="logModal" id="playerNotesModal" hidden aria-hidden="true">
  <div class="logModalBackdrop" data-player-notes-close="true"></div>
  <div class="logModalDialog" role="dialog" aria-modal="true" aria-labelledby="playerNotesModalTitle">
    <div class="logModalHeader">
      <h3 id="playerNotesModalTitle"><%= t("notes_details") %></h3>
      <button type="button" class="iconBtn" id="playerNotesTranslateBtn" aria-label="<%= t('translate_note') %>" title="<%= t('translate_note') %>">🌐</button>
      <button type="button" class="iconBtn" id="playerNotesModalClose" aria-label="<%= t('close') %>">✖</button>
    </div>
    <pre class="logModalBody" id="playerNotesModalBody"></pre>
  </div>
</div>

<script>
  (function () {
    const modal = document.getElementById("playerNotesModal");
    const modalBody = document.getElementById("playerNotesModalBody");
    const closeBtn = document.getElementById("playerNotesModalClose");
    const translateBtn = document.getElementById("playerNotesTranslateBtn");
    const targetLang = "<%= currentLang %>";
    const translationPrefix = "<%= t('translation_prefix') %>";
    const translatingLabel = "<%= t('translating_note') %>";
    const translationError = "<%= t('translation_error') %>";
    const sameLanguageMsg = "<%= t('translation_same_language') %>";
    if (!modal || !modalBody || !closeBtn || !translateBtn) return;

    let originalText = "";
    let translatedText = "";
    let sourceLang = "";

    function closeModal() {
      modal.hidden = true;
      modalBody.textContent = "";
      modal.setAttribute("aria-hidden", "true");
      translateBtn.disabled = false;
      originalText = "";
      translatedText = "";
      sourceLang = "";
    }

    function openModal(text) {
      originalText = String(text || "").trim();
      translatedText = "";
      sourceLang = "";
      modalBody.textContent = originalText;
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
    }

    function buildBodyText() {
      if (!translatedText) return originalText;
      const langInfo = sourceLang ? `${sourceLang} → ${targetLang}` : targetLang;
      return `${originalText}\n\n────────\n${translationPrefix} (${langInfo}):\n${translatedText}`;
    }

    document.querySelectorAll("[data-player-notes]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const nickname = btn.getAttribute("data-player-nickname") || "-";
        const notes = btn.getAttribute("data-player-notes") || "-";
        openModal(`${nickname}\n\n${notes}`);
      });
    });

    closeBtn.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      closeModal();
    });

    modal.addEventListener("click", (event) => {
      const target = event.target;
      if (target && target.closest("[data-player-notes-close='true']")) {
        closeModal();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !modal.hidden) {
        closeModal();
      }
    });

    translateBtn.addEventListener("click", async () => {
      if (!originalText) return;
      translateBtn.disabled = true;
      modalBody.textContent = `${buildBodyText()}\n\n${translatingLabel}`;

      try {
        const resp = await fetch("/potenze/translate-note", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ text: originalText, targetLang })
        });
        const data = await resp.json();

        if (!resp.ok || !data?.ok) {
          modalBody.textContent = `${buildBodyText()}\n\n${translationError}`;
          return;
        }

        if (data.sameLanguage) {
          modalBody.textContent = `${buildBodyText()}\n\n${sameLanguageMsg}`;
          return;
        }

        translatedText = String(data.translatedText || "").trim();
        sourceLang = String(data.sourceLang || "").trim().toLowerCase();
        modalBody.textContent = buildBodyText();
      } catch (err) {
        modalBody.textContent = `${buildBodyText()}\n\n${translationError}`;
      } finally {
        translateBtn.disabled = false;
      }
    });

    const historyModal = document.getElementById("playerHistoryModal");
    const historyCloseBtn = document.getElementById("playerHistoryModalClose");
    const historyMeta = document.getElementById("playerHistoryMeta");
    const historyTableBody = document.getElementById("playerHistoryTableBody");
    const historyCanvas = document.getElementById("playerHistoryCanvas");
    const historyLegend = document.getElementById("playerHistoryLegend");
    const historyTooltip = document.getElementById("playerHistoryTooltip");

    const HISTORY_RETENTION_DAYS = <%- JSON.stringify(historyRetentionDays) %>;
    const HISTORY_DAY_MS = 24 * 60 * 60 * 1000;
    const HISTORY_LAST_YEAR_RANGE_TEXT = <%- JSON.stringify(t("history_period_range")) %>;
    const HISTORY_PERIODS = [
      { key: "month", days: 30, label: <%- JSON.stringify(t("last_month")) %>, noData: <%- JSON.stringify(t("no_history_last_month")) %> },
      { key: "3months", days: 90, label: <%- JSON.stringify(t("last_3_months")) %>, noData: <%- JSON.stringify(t("no_history_last_3_months")) %> },
      { key: "6months", days: 180, label: <%- JSON.stringify(t("last_6_months")) %>, noData: <%- JSON.stringify(t("no_history_last_6_months")) %> },
      { key: "year", days: HISTORY_RETENTION_DAYS, label: <%- JSON.stringify(t("last_year")) %>, noData: <%- JSON.stringify(t("no_history_last_year")) %> }
    ];
    const localeTag = <%- JSON.stringify(localeTag) %>;

    const seriesConfig = [
      { key: "t1", label: "T1", color: "#3a67ff" },
      { key: "t2", label: "T2", color: "#2bd576" },
      { key: "t3", label: "T3", color: "#ffaf45" },
      { key: "t4", label: "T4", color: "#ff5c7a" },
      { key: "total", label: "TOT", color: "#b86bff" }
    ];
    const seriesVisibility = Object.fromEntries(seriesConfig.map((serie) => [serie.key, serie.key !== "total"]));
    let currentChartPoints = [];
    let currentDisplayChartPoints = [];
    let currentChartLayout = null;
    let currentHistoryScale = "daily";
    let currentHistoryPeriod = "year";
    let currentHistoryRows = [];
    let currentPlayerName = "";

    const formatPointValue = (value) => Number(value || 0).toLocaleString(localeTag, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const formatTableValue = (value) => Number(value || 0).toLocaleString(localeTag, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const monthYearFormatter = new Intl.DateTimeFormat(localeTag, { month: "short", year: "numeric", timeZone: "UTC" });
    const fullDateFormatter = new Intl.DateTimeFormat(localeTag, { day: "2-digit", month: "short", year: "numeric", timeZone: "UTC" });
    const numericDateFormatter = new Intl.DateTimeFormat(localeTag, { day: "2-digit", month: "2-digit", year: "numeric", timeZone: "UTC" });

    function parseIsoDayUTC(isoDay) {
      const dateObj = new Date(`${isoDay}T00:00:00Z`);
      return Number.isNaN(dateObj.getTime()) ? null : dateObj;
    }

    function formatMonthYear(isoDay) {
      const dateObj = parseIsoDayUTC(isoDay);
      return dateObj ? monthYearFormatter.format(dateObj) : String(isoDay || "");
    }

    function formatFullDate(isoDay) {
      const dateObj = parseIsoDayUTC(isoDay);
      return dateObj ? numericDateFormatter.format(dateObj) : String(isoDay || "");
    }

    function formatRangeDate(isoDay) {
      const dateObj = parseIsoDayUTC(isoDay);
      return dateObj ? fullDateFormatter.format(dateObj) : String(isoDay || "");
    }

    function getCurrentPeriod() {
      return HISTORY_PERIODS.find((period) => period.key === currentHistoryPeriod) || HISTORY_PERIODS[HISTORY_PERIODS.length - 1];
    }

    function getHistoryRangeLabel(points) {
      const period = getCurrentPeriod();
      if (!Array.isArray(points) || points.length === 0) return period.label;
      const start = formatRangeDate(points[0].date);
      const end = formatRangeDate(points[points.length - 1].date);
      return HISTORY_LAST_YEAR_RANGE_TEXT
        .replace("{period}", period.label)
        .replace("{range}", `${start} - ${end}`);
    }

    function getXAxisTicks(points) {
      if (!Array.isArray(points) || points.length === 0) return new Map();

      const ticks = new Map();
      const period = getCurrentPeriod();
      let lastMonthKey = "";
      let lastWeekKey = "";

      points.forEach((point, index) => {
        if (!point?.date) return;
        const dateObj = parseIsoDayUTC(point.date);
        if (!dateObj) return;
        const monthKey = `${dateObj.getUTCFullYear()}-${dateObj.getUTCMonth()}`;
        const weekKey = `${dateObj.getUTCFullYear()}-${Math.floor((dateObj.getTime() / HISTORY_DAY_MS) / 7)}`;
        if (period.key === "month") {
          if (index === 0 || index === points.length - 1 || dateObj.getUTCDate() % 7 === 1) ticks.set(point.date, formatFullDate(point.date));
          return;
        }
        if (period.key === "3months") {
          if (index === 0 || weekKey !== lastWeekKey && dateObj.getUTCDay() === 1) ticks.set(point.date, formatFullDate(point.date));
          lastWeekKey = weekKey;
          return;
        }
        if (index === 0 || monthKey !== lastMonthKey) {
          ticks.set(point.date, formatMonthYear(point.date));
          lastMonthKey = monthKey;
        }
      });

      return ticks;
    }

    const hasRealEntry = (point) => point?._real === true;

    function closeHistoryModal() {
      if (!historyModal) return;
      historyModal.hidden = true;
      historyModal.setAttribute("aria-hidden", "true");
      hideHistoryTooltip();
    }

    function openHistoryModal() {
      if (!historyModal) return;
      historyModal.hidden = false;
      historyModal.setAttribute("aria-hidden", "false");
    }

    function getVisibleSeries() {
      return seriesConfig.filter((serie) => seriesVisibility[serie.key] !== false);
    }

    function resizeHistoryCanvas() {
      if (!historyCanvas) return;
      const cssWidth = Math.max(320, Math.floor(historyCanvas.clientWidth || 980));
      const cssHeight = 320;

      if (historyCanvas.width !== cssWidth || historyCanvas.height !== cssHeight) {
        historyCanvas.width = cssWidth;
        historyCanvas.height = cssHeight;
      }
    }

    function getChartDisplayPoints(points) {
      if (currentHistoryScale !== "weekly" || !Array.isArray(points) || points.length === 0) return points;
      const weeks = [];
      for (let i = 0; i < points.length; i += 7) {
        const weekPoints = points.slice(i, i + 7);
        const realPoint = [...weekPoints].reverse().find(hasRealEntry);
        const lastPoint = weekPoints[weekPoints.length - 1];
        const sourcePoint = realPoint || lastPoint;
        if (!sourcePoint) continue;
        weeks.push({
          date: lastPoint.date,
          startDate: weekPoints[0]?.date || lastPoint.date,
          endDate: lastPoint.date,
          t1: Number(sourcePoint.t1 || 0),
          t2: Number(sourcePoint.t2 || 0),
          t3: Number(sourcePoint.t3 || 0),
          t4: Number(sourcePoint.t4 || 0),
          total: Number(sourcePoint.total || 0),
          _real: Boolean(realPoint)
        });
      }
      return weeks;
    }

    function drawHistoryChart(points) {
      if (!historyCanvas) return;
      points = getChartDisplayPoints(points);
      currentDisplayChartPoints = points;
      resizeHistoryCanvas();
      const ctx = historyCanvas.getContext("2d");
      const w = historyCanvas.width;
      const h = historyCanvas.height;
      const pad = { l: 56, r: 78, t: 16, b: 74 };
      const chartW = w - pad.l - pad.r;
      const chartH = h - pad.t - pad.b;
      currentChartLayout = { pad, chartW, chartH, width: w, height: h };
      const visibleSeries = getVisibleSeries();

      ctx.clearRect(0, 0, w, h);
      ctx.fillStyle = "#0d1424";
      ctx.fillRect(0, 0, w, h);

      if (!points || points.length === 0) {
        ctx.fillStyle = "#a9b6d3";
        ctx.font = "11px sans-serif";
        ctx.fillText(getCurrentPeriod().noData, 20, 26);
        return;
      }

      const numericValues = points.flatMap((point) =>
        visibleSeries
          .map((serie) => point[serie.key])
          .filter((value) => Number.isFinite(value))
      );
      const maxY = Math.max(1, ...(numericValues.length ? numericValues : [0]));
      const minY = 0;

      ctx.strokeStyle = "rgba(169,182,211,.25)";
      ctx.lineWidth = 1;
      for (let i = 0; i <= 5; i++) {
        const yy = pad.t + (chartH * i) / 5;
        ctx.beginPath();
        ctx.moveTo(pad.l, yy);
        ctx.lineTo(w - pad.r, yy);
        ctx.stroke();

        const val = (maxY - ((maxY - minY) * i) / 5).toFixed(0);
        ctx.fillStyle = "#a9b6d3";
        ctx.font = "11px sans-serif";
        ctx.fillText(val, 4, yy + 4);
      }

      const xForIndex = (i) => pad.l + (points.length === 1 ? chartW / 2 : (chartW * i) / (points.length - 1));
      const yForValue = (v) => pad.t + chartH - ((v - minY) / (maxY - minY)) * chartH;

      points.forEach((point, i) => {
        if (!hasRealEntry(point)) return;
        const x = xForIndex(i);
        ctx.save();
        ctx.setLineDash([4, 4]);
        ctx.strokeStyle = "rgba(184,107,255,.4)";
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(x, pad.t);
        ctx.lineTo(x, pad.t + chartH);
        ctx.stroke();
        ctx.restore();
      });

      const xAxisTicks = getXAxisTicks(points);
      points.forEach((p, i) => {
        const tickLabel = xAxisTicks.get(p.date);
        if (!tickLabel) return;
        const x = xForIndex(i);
        ctx.save();
        ctx.translate(x, h - 26);
        ctx.rotate(-Math.PI / 6);
        ctx.fillStyle = hasRealEntry(p) ? "#d4dcf0" : "#a9b6d3";
        ctx.font = "11px sans-serif";
        ctx.fillText(tickLabel, 0, 0);
        ctx.restore();
      });

      visibleSeries.forEach((serie) => {
        ctx.beginPath();
        ctx.lineWidth = 2;
        ctx.strokeStyle = serie.color;
        ctx.lineJoin = "round";
        ctx.lineCap = "round";
        let hasPath = false;
        points.forEach((point, i) => {
          const rawValue = point[serie.key];
          if (!Number.isFinite(rawValue)) {
            hasPath = false;
            return;
          }
          const x = xForIndex(i);
          const y = yForValue(rawValue);
          if (!hasPath) {
            ctx.moveTo(x, y);
            hasPath = true;
          } else {
            ctx.lineTo(x, y);
          }
        });
        ctx.stroke();

        let lastPoint = null;
        for (let i = points.length - 1; i >= 0; i--) {
          const point = points[i];
          const rawValue = point[serie.key];
          if (!Number.isFinite(rawValue)) continue;
          lastPoint = { index: i, value: rawValue };
          break;
        }
        if (!lastPoint) return;

        const labelX = Math.min(w - pad.r + 6, xForIndex(lastPoint.index) + 8);
        const labelY = yForValue(lastPoint.value);
        ctx.fillStyle = serie.color;
        ctx.font = "bold 11px sans-serif";
        ctx.textBaseline = "middle";
        ctx.fillText(`${serie.label} ${formatPointValue(lastPoint.value)}`, labelX, labelY);
      });
    }

    function hideHistoryTooltip() {
      if (!historyTooltip) return;
      historyTooltip.hidden = true;
      historyTooltip.innerHTML = "";
    }

    function showHistoryTooltip(event) {
      if (!historyTooltip || !historyCanvas || !currentChartLayout || !currentDisplayChartPoints.length) return;
      const rect = historyCanvas.getBoundingClientRect();
      const cssX = event.clientX - rect.left;
      const canvasX = cssX * (historyCanvas.width / rect.width);
      const { pad, chartW } = currentChartLayout;
      if (canvasX < pad.l || canvasX > historyCanvas.width - pad.r) {
        hideHistoryTooltip();
        return;
      }

      const lastIndex = currentDisplayChartPoints.length - 1;
      const rawIndex = lastIndex === 0 ? 0 : Math.round(((canvasX - pad.l) / chartW) * lastIndex);
      const pointIndex = Math.min(lastIndex, Math.max(0, rawIndex));
      const point = currentDisplayChartPoints[pointIndex];
      if (!point) {
        hideHistoryTooltip();
        return;
      }

      const tooltipDate = currentHistoryScale === "weekly" && point.startDate && point.endDate
        ? `${formatFullDate(point.startDate)} - ${formatFullDate(point.endDate)}`
        : formatFullDate(point.date);
      const rows = [`<strong>${tooltipDate}</strong>`];
      getVisibleSeries().forEach((serie) => {
        rows.push(`<span style="color:${serie.color}">${serie.label}: ${formatPointValue(point[serie.key])}</span>`);
      });
      historyTooltip.innerHTML = rows.join("<br>");
      historyTooltip.hidden = false;
      historyTooltip.style.left = `${Math.min(rect.width - 180, Math.max(8, cssX + 12))}px`;
      historyTooltip.style.top = `${Math.max(8, event.clientY - rect.top - 12)}px`;
    }

    function renderLegend() {
      if (!historyLegend) return;
      historyLegend.innerHTML = seriesConfig
        .map((serie) => {
          const inactiveClass = seriesVisibility[serie.key] === false ? " legendItemOff" : "";
          return `<button type="button" class="legendItem${inactiveClass}" data-series-key="${serie.key}" aria-pressed="${seriesVisibility[serie.key] !== false}"><span class="legendDot" style="background:${serie.color}"></span>${serie.label}</button>`;
        })
        .join("");

      historyLegend.querySelectorAll("[data-series-key]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const key = btn.getAttribute("data-series-key");
          if (!key || !(key in seriesVisibility)) return;
          seriesVisibility[key] = !seriesVisibility[key];
          renderLegend();
          drawHistoryChart(currentChartPoints);
        });
      });
    }

    function updateHistoryControls() {
      const controls = document.getElementById("historyScaleControls");
      if (!controls) return;
      controls.querySelectorAll("[data-history-scale]").forEach((item) => {
        const active = item.getAttribute("data-history-scale") === currentHistoryScale;
        item.classList.toggle("isActive", active);
        item.setAttribute("aria-pressed", active ? "true" : "false");
      });
      controls.querySelectorAll("[data-history-period]").forEach((item) => {
        const active = item.getAttribute("data-history-period") === currentHistoryPeriod;
        item.classList.toggle("isActive", active);
        item.setAttribute("aria-pressed", active ? "true" : "false");
      });
    }

    function setupScaleControls() {
      const controls = document.getElementById("historyScaleControls");
      if (!controls) return;
      controls.querySelectorAll("[data-history-scale]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const selected = btn.getAttribute("data-history-scale");
          if (!selected || (selected !== "daily" && selected !== "weekly")) return;
          currentHistoryScale = selected;
          updateHistoryControls();
          drawHistoryChart(currentChartPoints);
        });
      });
      controls.querySelectorAll("[data-history-period]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const selected = btn.getAttribute("data-history-period");
          if (!HISTORY_PERIODS.some((period) => period.key === selected)) return;
          currentHistoryPeriod = selected;
          updateHistoryView();
        });
      });
    }

    function toIsoDayUTC(dateObj) {
      const y = dateObj.getUTCFullYear();
      const m = String(dateObj.getUTCMonth() + 1).padStart(2, "0");
      const d = String(dateObj.getUTCDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    function buildLastDaysForChart(realRows, daysCount) {
      const count = Number.isFinite(daysCount) ? Math.max(1, Math.floor(daysCount) + 1) : HISTORY_RETENTION_DAYS + 1;
      const rowsByDay = new Map(
        (realRows || [])
          .filter((row) => row && row.date)
          .map((row) => [String(row.date), row])
      );

      const now = new Date();
      const startUTC = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() - (count - 1), 0, 0, 0, 0));
      const result = [];
      let lastKnown = null;
      for (let i = 0; i < count; i++) {
        const dayUTC = new Date(startUTC.getTime() + i * HISTORY_DAY_MS);
        const isoDay = toIsoDayUTC(dayUTC);
        const realRow = rowsByDay.get(isoDay);
        if (realRow) {
          const normalized = {
            date: isoDay,
            t1: Number(realRow.t1 || 0),
            t2: Number(realRow.t2 || 0),
            t3: Number(realRow.t3 || 0),
            t4: Number(realRow.t4 || 0),
            total: Number(realRow.total || 0),
            _real: true
          };
          result.push(normalized);
          lastKnown = normalized;
        } else {
          if (!lastKnown) {
            result.push({
              date: isoDay,
              t1: 0,
              t2: 0,
              t3: 0,
              t4: 0,
              total: 0,
              _real: false
            });
            continue;
          }
          result.push({
            date: isoDay,
            t1: lastKnown.t1,
            t2: lastKnown.t2,
            t3: lastKnown.t3,
            t4: lastKnown.t4,
            total: lastKnown.total,
            _real: false
          });
        }
      }
      return result;
    }

    function getPeriodStartIso(period) {
      const now = new Date();
      return toIsoDayUTC(new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() - period.days, 0, 0, 0, 0)));
    }

    function chooseDefaultHistoryPeriod(rows) {
      if (!Array.isArray(rows) || rows.length === 0) return "month";
      const oldest = rows.reduce((min, row) => row?.date && (!min || String(row.date) < min) ? String(row.date) : min, "");
      if (!oldest) return "month";
      for (const period of HISTORY_PERIODS) {
        if (oldest >= getPeriodStartIso(period)) return period.key;
      }
      return "year";
    }

    function buildFilledTableRows(rows) {
      const sortedAsc = [...(rows || [])].sort((a, b) => String(a.date || "").localeCompare(String(b.date || "")));
      const filledAscRows = [];
      let previousSnapshot = null;
      sortedAsc.forEach((row) => {
        const current = {
          date: String(row.date || ""),
          t1: Number(row.t1),
          t2: Number(row.t2),
          t3: Number(row.t3),
          t4: Number(row.t4)
        };

        ["t1", "t2", "t3", "t4"].forEach((key) => {
          if (Number.isFinite(current[key])) return;
          current[key] = previousSnapshot ? Number(previousSnapshot[key] || 0) : 0;
        });
        current.total = Math.round((current.t1 + current.t2 + current.t3 + current.t4) * 100) / 100;

        if (previousSnapshot) {
          current.growth = {};
          ["t1", "t2", "t3", "t4", "total"].forEach((key) => {
            const prevVal = Number(previousSnapshot[key] || 0);
            const currVal = Number(current[key] || 0);
            if (!Number.isFinite(prevVal) || !Number.isFinite(currVal) || prevVal === 0) {
              current.growth[key] = null;
              return;
            }
            const pct = ((currVal - prevVal) / prevVal) * 100;
            current.growth[key] = Number.isFinite(pct) ? pct : null;
          });
        } else {
          current.growth = { t1: null, t2: null, t3: null, t4: null, total: null };
        }

        filledAscRows.push(current);
        previousSnapshot = current;
      });
      return filledAscRows;
    }

    function updateHistoryView() {
      const period = getCurrentPeriod();
      const periodStart = getPeriodStartIso(period);
      const rowsInPeriod = currentHistoryRows.filter((row) => String(row?.date || "") >= periodStart);
      const chartRows = buildLastDaysForChart(rowsInPeriod, period.days);
      currentChartPoints = chartRows;
      historyMeta.textContent = `${currentPlayerName} · ${getHistoryRangeLabel(chartRows)}`;
      updateHistoryControls();
      if (!rowsInPeriod.length) {
        historyTableBody.innerHTML = `<tr><td colspan="5" class="muted">${period.noData}</td></tr>`;
        drawHistoryChart(chartRows);
        return;
      }

      const displayRows = buildFilledTableRows(rowsInPeriod).reverse();
      const renderCell = (value, growthPct) => {
        const valueHtml = formatTableValue(value);
        if (!Number.isFinite(growthPct) || growthPct === 0) return valueHtml;
        const growthSign = growthPct > 0 ? "+" : "-";
        const growthClass = growthPct > 0 ? "historyGrowth" : "historyGrowth historyGrowthNegative";
        const growthText = `(${growthSign}${Math.abs(growthPct).toFixed(2)}%)`;
        return `${valueHtml} <span class="${growthClass}">${growthText}</span>`;
      };

      historyTableBody.innerHTML = displayRows
        .map((row) => `<tr><td class="historyDateCell">${row.date}</td><td>${renderCell(row.t1, row.growth?.t1)}</td><td>${renderCell(row.t2, row.growth?.t2)}</td><td>${renderCell(row.t3, row.growth?.t3)}</td><td>${renderCell(row.t4, row.growth?.t4)}</td></tr>`)
        .join("");

      drawHistoryChart(chartRows);
    }

    async function openPlayerHistory(playerId, playerName) {
      seriesConfig.forEach((serie) => {
        seriesVisibility[serie.key] = serie.key !== "total";
      });
      seriesVisibility.t4 = false;
      currentChartPoints = [];
      currentHistoryRows = [];
      currentPlayerName = playerName;
      currentHistoryScale = "daily";
      currentHistoryPeriod = "year";
      updateHistoryControls();
      openHistoryModal();
      historyMeta.textContent = `${playerName} · ${getCurrentPeriod().label}`;
      historyTableBody.innerHTML = `<tr><td colspan="5" class="muted"><%= t("history_loading") %></td></tr>`;
      renderLegend();
      drawHistoryChart([]);

      try {
        const resp = await fetch(`/potenze/${playerId}/history-data?days=${HISTORY_RETENTION_DAYS}`);
        const data = await resp.json();
        if (!resp.ok || !data?.ok) throw new Error("history_error");

        const rows = data.history || [];
        currentHistoryRows = rows;
        currentHistoryPeriod = chooseDefaultHistoryPeriod(rows);
        const hasT4Entries = rows.some((row) => Number(row?.t4 || 0) > 0);
        seriesVisibility.t4 = hasT4Entries;
        renderLegend();
        updateHistoryView();
      } catch (err) {
        historyTableBody.innerHTML = `<tr><td colspan="5" class="muted"><%= t("err_internal") %></td></tr>`;
      }
    }

    setupScaleControls();

    if (historyCanvas) {
      historyCanvas.addEventListener("mousemove", showHistoryTooltip);
      historyCanvas.addEventListener("mouseleave", hideHistoryTooltip);
    }

    window.addEventListener("resize", () => {
      if (historyModal && !historyModal.hidden) {
        drawHistoryChart(currentChartPoints);
      }
    });

    document.querySelectorAll(".playerHistoryOpenBtn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const playerId = btn.getAttribute("data-player-id");
        const playerName = btn.getAttribute("data-player-name") || "-";
        if (!playerId) return;
        openPlayerHistory(playerId, playerName);
      });
    });

    if (historyCloseBtn) {
      historyCloseBtn.addEventListener("click", (event) => {
        event.preventDefault();
        closeHistoryModal();
      });
    }

    if (historyModal) {
      historyModal.addEventListener("click", (event) => {
        const target = event.target;
        if (target && target.closest("[data-player-history-close='true']")) {
          closeHistoryModal();
        }
      });
    }

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && historyModal && !historyModal.hidden) {
        closeHistoryModal();
      }
    });

  })();
</script>

<%- include("../partials/footer") %>
