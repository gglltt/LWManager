<%- include("../partials/header") %>

<%
  function fmt2(v) {
    if (v === null || v === undefined || v === "") return "-";
    const n = Number(v);
    if (Number.isNaN(n)) return "-";
    return n.toLocaleString("it-IT", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function sortLink(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";

    let nextDir = "asc";
    if (currentSort === field && currentDir === "asc") nextDir = "desc";
    if (currentSort === field && currentDir === "desc") nextDir = "asc";

    return `/potenze?sort=${encodeURIComponent(field)}&dir=${encodeURIComponent(nextDir)}`;
  }

  function sortArrow(field) {
    const currentSort = sort || "updatedAt";
    const currentDir = dir || "desc";
    if (currentSort !== field) return "";
    return currentDir === "asc" ? " ▲" : " ▼";
  }
%>

<section class="card cardWide">
  <div class="pageHeader">
    <div>
      <h1>Potenze</h1>
      <p class="muted">Gestione lista giocatori. Ultimo aggiornamento gestito automaticamente dal sistema.</p>
    </div>

    <div class="pageHeaderActions">
      <a class="button secondary" href="/dashboard">← Dashboard</a>

      <% if (isAdmin) { %>
        <a class="button" href="/potenze/new">+ Nuovo giocatore</a>
      <% } %>
    </div>
  </div>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <div class="tableWrap">
    <table class="table">
      <thead>
        <tr>
          <th><a class="thLink" href="<%= sortLink('nickname') %>">Nickname<%= sortArrow('nickname') %></a></th>
          <th><a class="thLink" href="<%= sortLink('role') %>">Ruolo<%= sortArrow('role') %></a></th>

          <th><a class="thLink" href="<%= sortLink('powerT1') %>">T1<%= sortArrow('powerT1') %></a></th>
          <th><a class="thLink" href="<%= sortLink('typeT1') %>">Tipo T1<%= sortArrow('typeT1') %></a></th>

          <th><a class="thLink" href="<%= sortLink('powerT2') %>">T2<%= sortArrow('powerT2') %></a></th>
          <th><a class="thLink" href="<%= sortLink('typeT2') %>">Tipo T2<%= sortArrow('typeT2') %></a></th>

          <th><a class="thLink" href="<%= sortLink('powerT3') %>">T3<%= sortArrow('powerT3') %></a></th>
          <th><a class="thLink" href="<%= sortLink('typeT3') %>">Tipo T3<%= sortArrow('typeT3') %></a></th>

          <th><a class="thLink" href="<%= sortLink('powerT4') %>">T4<%= sortArrow('powerT4') %></a></th>
          <th><a class="thLink" href="<%= sortLink('typeT4') %>">Tipo T4<%= sortArrow('typeT4') %></a></th>

          <th><a class="thLink" href="<%= sortLink('total') %>">Totale<%= sortArrow('total') %></a></th>
          <th><a class="thLink" href="<%= sortLink('updatedAt') %>">Aggiornato<%= sortArrow('updatedAt') %></a></th>

          <th>Note</th>
          <% if (isAdmin) { %>
            <th>Azioni</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (!players || players.length === 0) { %>
          <tr>
            <td colspan="<%= isAdmin ? 14 : 13 %>" class="muted">Nessun giocatore inserito.</td>
          </tr>
        <% } %>

        <% players.forEach(p => { %>
          <tr>
            <td><b><%= p.nickname %></b></td>
            <td><%= p.role || "-" %></td>

            <td><%= fmt2(p.powerT1) %></td>
            <td><%= p.typeT1 || "-" %></td>

            <td><%= fmt2(p.powerT2) %></td>
            <td><%= p.typeT2 || "-" %></td>

            <td><%= fmt2(p.powerT3) %></td>
            <td><%= p.typeT3 || "-" %></td>

            <td><%= fmt2(p.powerT4) %></td>
            <td><%= p.typeT4 || "-" %></td>

            <td><b><%= fmt2(p.total) %></b></td>

            <td><%= p.updatedAt ? new Date(p.updatedAt).toLocaleString("it-IT") : "-" %></td>

            <td class="noteCell">
              <% if (p.notes && String(p.notes).trim().length > 0) { %>
                <span title="<%= p.notes %>"><%= p.notes.length > 80 ? (p.notes.slice(0, 80) + "…") : p.notes %></span>
              <% } else { %>
                -
              <% } %>
            </td>

            <% if (isAdmin) { %>
              <td class="actionsCell">
                <a class="linkBtn" href="/potenze/<%= p._id %>/edit">Modifica</a>
                <form method="POST" action="/potenze/<%= p._id %>/delete" class="inlineForm" onsubmit="return confirm('Confermi la cancellazione di <%= p.nickname %>?');">
                  <button class="linkBtn danger" type="submit">Elimina</button>
                </form>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (!isAdmin) { %>
    <p class="muted" style="margin-top: 12px;">
      Solo gli utenti di livello 5 possono inserire, modificare o cancellare giocatori.
    </p>
  <% } %>
</section>

<%- include("../partials/footer") %>