<%- include("../partials/header") %>

<section class="card cardWide">
  <div class="pageHeader">
    <div>
      <h1>Modifica giocatore</h1>
      <p class="muted">Ultimo aggiornamento: <%= player.updatedAt ? new Date(player.updatedAt).toLocaleString("it-IT") : "-" %></p>
    </div>

    <div class="pageHeaderActions">
      <a class="button secondary" href="/potenze">← Potenze</a>
    </div>
  </div>

  <% if (message) { %>
    <div class="alert success"><%= message %></div>
  <% } %>

  <% if (error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <form class="form" method="POST" action="/potenze/<%= player._id %>">
    <div class="formGrid2">
      <div class="field">
        <label for="nickname">Nickname (obbligatorio)</label>
        <input id="nickname" name="nickname" type="text" required value="<%= player.nickname || '' %>" />
      </div>

      <div class="field">
        <label for="role">Ruolo (opzionale)</label>
        <select id="role" name="role">
          <option value="" <%= !player.role ? 'selected' : '' %>>—</option>
          <% roles.forEach(r => { %>
            <option value="<%= r %>" <%= player.role === r ? 'selected' : '' %>><%= r %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <hr class="divider" />

    <div class="formGrid2">
      <div class="field">
        <label for="powerT1">Power T1 (2 decimali)</label>
        <input id="powerT1" name="powerT1" type="text" inputmode="decimal" value="<%= (player.powerT1 ?? '') %>" placeholder="0,00" />
        <div class="help">Accetta “,” o “.”</div>
      </div>

      <div class="field">
        <label for="typeT1">Type T1</label>
        <select id="typeT1" name="typeT1">
          <option value="" <%= !player.typeT1 ? 'selected' : '' %>>—</option>
          <% types.forEach(t => { %>
            <option value="<%= t %>" <%= player.typeT1 === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label for="powerT2">Power T2 (2 decimali)</label>
        <input id="powerT2" name="powerT2" type="text" inputmode="decimal" value="<%= (player.powerT2 ?? '') %>" placeholder="0,00" />
        <div class="help">Accetta “,” o “.”</div>
      </div>

      <div class="field">
        <label for="typeT2">Type T2</label>
        <select id="typeT2" name="typeT2">
          <option value="" <%= !player.typeT2 ? 'selected' : '' %>>—</option>
          <% types.forEach(t => { %>
            <option value="<%= t %>" <%= player.typeT2 === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label for="powerT3">Power T3 (2 decimali)</label>
        <input id="powerT3" name="powerT3" type="text" inputmode="decimal" value="<%= (player.powerT3 ?? '') %>" placeholder="0,00" />
        <div class="help">Accetta “,” o “.”</div>
      </div>

      <div class="field">
        <label for="typeT3">Type T3</label>
        <select id="typeT3" name="typeT3">
          <option value="" <%= !player.typeT3 ? 'selected' : '' %>>—</option>
          <% types.forEach(t => { %>
            <option value="<%= t %>" <%= player.typeT3 === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label for="powerT4">Power T4 (2 decimali)</label>
        <input id="powerT4" name="powerT4" type="text" inputmode="decimal" value="<%= (player.powerT4 ?? '') %>" placeholder="0,00" />
        <div class="help">Accetta “,” o “.”</div>
      </div>

      <div class="field">
        <label for="typeT4">Type T4</label>
        <select id="typeT4" name="typeT4">
          <option value="" <%= !player.typeT4 ? 'selected' : '' %>>—</option>
          <% types.forEach(t => { %>
            <option value="<%= t %>" <%= player.typeT4 === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="field">
      <label for="notes">Note (opzionale)</label>
      <textarea id="notes" name="notes" placeholder="Testo libero..."><%= player.notes || '' %></textarea>
    </div>

    <div class="formActions">
      <button type="submit">Salva modifiche</button>

      <form class="inlineForm" method="POST" action="/potenze/<%= player._id %>/delete" onsubmit="return confirm('Confermi la cancellazione di <%= player.nickname %>?');">
        <button class="button danger" type="submit">Elimina giocatore</button>
      </form>

      <a class="button secondary" href="/potenze">Annulla</a>
    </div>
  </form>
</section>

<%- include("../partials/footer") %>