<%- include("../partials/header") %>

<section class="card cardWide eventLogPage">
  <div class="pageHeader eventLogHeader">
    <div>
      <h1><%= t("event_log_title") %></h1>
      <p class="muted"><%= t("event_log_desc") %></p>
    </div>
  </div>

  <% if (typeof error !== "undefined" && error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>
  <% if (typeof trackingMessage !== "undefined" && trackingMessage) { %>
    <div class="alert success"><%= trackingMessage %></div>
  <% } %>

  <div class="eventLogToolbar">
    <form method="GET" action="/registro" class="eventLogFilterBar">
      <label class="eventLogFilterField">
        <span><%= t("activity_type") %></span>
        <select name="eventType" class="filterInput eventLogFilterSelect">
          <option value=""><%= t("all_activities") %></option>
          <% (eventTypes || []).forEach(type => { %>
            <option value="<%= type %>" <%= selectedEventType === type ? "selected" : "" %>><%= type %></option>
          <% }) %>
        </select>
      </label>
      <div class="eventLogFilterActions">
        <button class="button" type="submit"><%= t("filter") %></button>
        <% if (selectedEventType) { %>
          <a class="button secondary" href="/registro"><%= t("reset") %></a>
        <% } %>
      </div>
    </form>
    <div class="eventLogTotal" aria-live="polite">
      <span class="muted"><%= t("total_results") %>:</span>
      <strong><%= total || 0 %></strong>
    </div>
  </div>

  <%
    const currentPage = Math.max(1, Number(page) || 1);
    const pagesCount = Math.max(1, Number(totalPages) || 1);
    const selectedEventTypeParam = encodeURIComponent(selectedEventType || "");
    const pageHref = (pageNumber) => `/registro?page=${pageNumber}&eventType=${selectedEventTypeParam}`;
    const prevPage = currentPage > 1 ? currentPage - 1 : null;
    const nextPage = currentPage < pagesCount ? currentPage + 1 : null;
    const pageItems = [];
    for (let pageNumber = 1; pageNumber <= pagesCount; pageNumber += 1) {
      if (pageNumber === 1 || pageNumber === pagesCount || Math.abs(pageNumber - currentPage) <= 1) {
        pageItems.push(pageNumber);
      } else if (pageItems[pageItems.length - 1] !== "ellipsis") {
        pageItems.push("ellipsis");
      }
    }
  %>

  <% function renderPagination(position) { %>
    <nav class="eventLogPagination eventLogPagination--<%= position %>" aria-label="<%= t('pagination') %>">
      <div class="eventLogPageStatus"><%= t("page_x_of_y").replace("{current}", currentPage).replace("{total}", pagesCount) %></div>
      <div class="eventLogPageButtons">
        <% if (prevPage) { %>
          <a class="button secondary" href="<%= pageHref(prevPage) %>">← <%= t("previous") %></a>
        <% } else { %>
          <span class="button secondary disabled" aria-disabled="true">← <%= t("previous") %></span>
        <% } %>
        <% pageItems.forEach((item) => { %>
          <% if (item === "ellipsis") { %>
            <span class="eventLogPageEllipsis" aria-hidden="true">…</span>
          <% } else if (item === currentPage) { %>
            <span class="button eventLogPageNumber active" aria-current="page"><%= item %></span>
          <% } else { %>
            <a class="button secondary eventLogPageNumber" href="<%= pageHref(item) %>"><%= item %></a>
          <% } %>
        <% }) %>
        <% if (nextPage) { %>
          <a class="button secondary" href="<%= pageHref(nextPage) %>"><%= t("next") %> →</a>
        <% } else { %>
          <span class="button secondary disabled" aria-disabled="true"><%= t("next") %> →</span>
        <% } %>
      </div>
    </nav>
  <% } %>

  <% renderPagination("top"); %>

  <div class="tableWrap eventLogTableWrap">
    <table class="table tableEssentialLogs eventLogTable">
      <thead>
        <tr>
          <th><%= t("when") %></th>
          <th><%= t("activity") %></th>
          <th><%= t("origin") %></th>
          <th><%= t("details") %></th>
          <th><%= t("actions_short") %></th>
        </tr>
      </thead>
      <tbody>
        <% if (!events || events.length === 0) { %>
          <tr><td colspan="5" class="muted eventLogEmpty"><%= t("no_events") %></td></tr>
        <% } %>
        <% (events || []).forEach((event) => {
          const dt = new Date(event.createdAt);
          const date = Number.isNaN(dt.getTime()) ? "-" : dt.toLocaleDateString(localeTag);
          const time = Number.isNaN(dt.getTime()) ? "-" : dt.toLocaleTimeString(localeTag, { hour: "2-digit", minute: "2-digit", second: "2-digit" });
          const details = event.details || "-";
          const unknown = t("unknown");
          const sourceSummary = [event.sourceIp || unknown, event.sourceCity || unknown, event.sourceCountry || unknown].filter(Boolean).join(" · ");
          const fullDetails = [
            `${t("date")}: ${date} ${time}`,
            `${t("activity")}: ${event.eventType || "-"}`,
            `${t("source_ip")}: ${event.sourceIp || unknown}`,
            `${t("browser")}: ${event.browserType || unknown}`,
            `${t("machine")}: ${event.sourceMachine || unknown}`,
            `${t("city")}: ${event.sourceCity || unknown}`,
            `${t("region")}: ${event.sourceRegion || unknown}`,
            `${t("country")}: ${event.sourceCountry || unknown}`,
            `User-Agent: ${event.userAgent || unknown}`,
            "",
            `${t("details")}:`,
            details
          ].join("\n");
        %>
          <tr>
            <td data-label="<%= t('when') %>"><div class="cell2"><span class="cellTop"><%= date %></span><span class="cellSub muted"><%= time %></span></div></td>
            <td data-label="<%= t('activity') %>"><span class="eventLogActivity" title="<%= event.eventType || '-' %>"><%= event.eventType || '-' %></span></td>
            <td data-label="<%= t('origin') %>"><span class="eventLogOrigin" title="<%= sourceSummary %>"><%= sourceSummary %></span></td>
            <td data-label="<%= t('details') %>"><span class="eventLogDetailsText" title="<%= details %>"><%= details %></span></td>
            <td data-label="<%= t('actions_short') %>" class="eventLogActionCell"><button type="button" class="button secondary logDetailsBtn" data-log-details="<%= fullDetails %>"><%= t("open") %></button></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% renderPagination("bottom"); %>
</section>

<div class="logModal" id="logModal" hidden aria-hidden="true">
  <div class="logModalBackdrop" data-log-close="true"></div>
  <div class="logModalDialog" role="dialog" aria-modal="true" aria-labelledby="logModalTitle">
    <div class="logModalHeader">
      <h3 id="logModalTitle"><%= t("event_details") %></h3>
      <button type="button" class="iconBtn" id="logModalClose" aria-label="<%= t('close') %>">✖</button>
    </div>
    <pre class="logModalBody event-user-agent" id="logModalBody"></pre>
  </div>
</div>

<script>
  (function () {
    const modal = document.getElementById("logModal");
    const modalBody = document.getElementById("logModalBody");
    const closeBtn = document.getElementById("logModalClose");
    if (!modal || !modalBody || !closeBtn) return;

    function closeModal() {
      modal.hidden = true;
      modalBody.textContent = "";
      modal.setAttribute("aria-hidden", "true");
    }

    function openModal(text) {
      modalBody.textContent = text;
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
    }

    document.querySelectorAll("[data-log-details]").forEach((btn) => {
      btn.addEventListener("click", () => {
        openModal(btn.getAttribute("data-log-details") || "-");
      });
    });

    closeBtn.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      closeModal();
    });

    modal.addEventListener("click", (event) => {
      const target = event.target;
      if (target && target.closest("[data-log-close='true']")) {
        closeModal();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !modal.hidden) {
        closeModal();
      }
    });
  })();
</script>

<%- include("../partials/footer") %>
