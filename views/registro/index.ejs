<%- include("../partials/header") %>

<section class="card cardWide">
  <div class="pageHeader">
    <div>
      <h1><%= t("event_log_title") %></h1>
      <p class="muted"><%= t("event_log_desc") %></p>
    </div>
    <div class="pageHeaderActions">
      <form method="POST" action="/registro/tracking/rebuild" class="inlineForm">
        <button class="button secondary" type="submit">Genera tracking table</button>
      </form>
      <a class="button secondary" href="/dashboard">← <%= t("back_dashboard") %></a>
    </div>
  </div>

  <% if (typeof error !== "undefined" && error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>
  <% if (typeof trackingMessage !== "undefined" && trackingMessage) { %>
    <div class="alert success"><%= trackingMessage %></div>
  <% } %>

  <form method="GET" action="/registro" class="filterBar">
    <select name="eventType" class="filterInput">
      <option value=""><%= t("all_activities") %></option>
      <% (eventTypes || []).forEach(type => { %>
        <option value="<%= type %>" <%= selectedEventType === type ? "selected" : "" %>><%= type %></option>
      <% }) %>
    </select>
    <button class="button" type="submit"><%= t("filter") %></button>
  </form>

  <div class="muted" style="margin-bottom:8px;"><%= t("total_results") %>: <%= total || 0 %></div>

  <div class="tableWrap">
    <table class="table tableEssentialLogs">
      <thead>
        <tr>
          <th><%= t("when") %></th>
          <th><%= t("activity") %></th>
          <th><%= t("origin") %></th>
          <th><%= t("details") %></th>
        </tr>
      </thead>
      <tbody>
        <% if (!events || events.length === 0) { %>
          <tr><td colspan="4" class="muted"><%= t("no_events") %></td></tr>
        <% } %>
        <% (events || []).forEach((event, idx) => {
          const dt = new Date(event.createdAt);
          const date = Number.isNaN(dt.getTime()) ? "-" : dt.toLocaleDateString(localeTag);
          const time = Number.isNaN(dt.getTime()) ? "-" : dt.toLocaleTimeString(localeTag, { hour: "2-digit", minute: "2-digit", second: "2-digit" });
          const details = event.details || "-";
          const detailsPreview = details.length > 80 ? `${details.slice(0, 80)}…` : details;
          const sourceSummary = [event.sourceIp, event.sourceCity || t("unknown")].filter(Boolean).join(" · ");
          const fullDetails = [
            `${t("date")}: ${date} ${time}`,
            `${t("activity")}: ${event.eventType || "-"}`,
            `${t("source_ip")}: ${event.sourceIp || t("unknown")}`,
            `${t("browser")}: ${event.browserType || t("unknown")}`,
            `${t("machine")}: ${event.sourceMachine || t("unknown")}`,
            `${t("city")}: ${event.sourceCity || t("unknown")}`,
            "",
            `${t("details")}:`,
            details
          ].join("\n");
        %>
          <tr>
            <td>
              <div class="cell2">
                <span class="cellTop"><%= date %></span>
                <span class="cellSub muted"><%= time %></span>
              </div>
            </td>
            <td><%= event.eventType %></td>
            <td><%= sourceSummary %></td>
            <td>
              <div class="logDetailsCell">
                <span class="logDetailsPreview"><%= detailsPreview %></span>
                <% if (details !== "-") { %>
                  <button
                    type="button"
                    class="button secondary logDetailsBtn"
                    data-log-details="<%= fullDetails %>">
                    <%= t("open") %>
                  </button>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <% const prevPage = page > 1 ? page - 1 : null; %>
    <% const nextPage = page < totalPages ? page + 1 : null; %>

    <% if (prevPage) { %>
      <a class="button secondary" href="/registro?page=<%= prevPage %>&eventType=<%= encodeURIComponent(selectedEventType || '') %>">← <%= t("previous") %></a>
    <% } %>

    <span class="muted"><%= t("page") %> <%= page %> <%= t("of") %> <%= totalPages %></span>

    <% if (nextPage) { %>
      <a class="button secondary" href="/registro?page=<%= nextPage %>&eventType=<%= encodeURIComponent(selectedEventType || '') %>"><%= t("next") %> →</a>
    <% } %>
  </div>
</section>

<div class="logModal" id="logModal" hidden aria-hidden="true">
  <div class="logModalBackdrop" data-log-close="true"></div>
  <div class="logModalDialog" role="dialog" aria-modal="true" aria-labelledby="logModalTitle">
    <div class="logModalHeader">
      <h3 id="logModalTitle"><%= t("event_details") %></h3>
      <button type="button" class="iconBtn" id="logModalClose" aria-label="<%= t('close') %>">✖</button>
    </div>
    <pre class="logModalBody" id="logModalBody"></pre>
  </div>
</div>

<script>
  (function () {
    const modal = document.getElementById("logModal");
    const modalBody = document.getElementById("logModalBody");
    const closeBtn = document.getElementById("logModalClose");
    if (!modal || !modalBody || !closeBtn) return;

    function closeModal() {
      modal.hidden = true;
      modalBody.textContent = "";
      modal.setAttribute("aria-hidden", "true");
    }

    function openModal(text) {
      modalBody.textContent = text;
      modal.hidden = false;
      modal.setAttribute("aria-hidden", "false");
    }

    document.querySelectorAll("[data-log-details]").forEach((btn) => {
      btn.addEventListener("click", () => {
        openModal(btn.getAttribute("data-log-details") || "-");
      });
    });

    closeBtn.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      closeModal();
    });

    modal.addEventListener("click", (event) => {
      const target = event.target;
      if (target && target.closest("[data-log-close='true']")) {
        closeModal();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !modal.hidden) {
        closeModal();
      }
    });
  })();
</script>

<%- include("../partials/footer") %>
