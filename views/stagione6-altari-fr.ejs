  <nav class="seasonToc" aria-label="Index du guide Autels Saison 6">
    <a href="#quando">Quand</a><a href="#regole">Règles</a><a href="#abilita">Compétence</a><a href="#strategia">Stratégie</a><a href="#checklist">Checklist</a>
