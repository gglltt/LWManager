<%- include("../partials/header") %>

<section class="card cardWide passwordsPage">
  <div class="pageHeader passwordsHeader">
    <div>
      <h1><%= t("password_management") %></h1>
      <p class="muted">
        <% if (user && user.isMaster) { %>
          <%= t("password_management_master_intro") %>
        <% } else { %>
          <%= t("password_management_supervisor_intro") %>
        <% } %>
      </p>
    </div>
  </div>

  <% if (message) { %><div class="alert success"><%= message %></div><% } %>
  <% if (error) { %><div class="alert error"><%= error %></div><% } %>

  <div class="passwordList" role="list">
    <% if (!accounts.length) { %>
      <div class="passwordAccountCard passwordAccountCard--empty" role="listitem"><%= t("no_users_available") %></div>
    <% } %>

    <% accounts.forEach((account) => { %>
      <article class="passwordAccountCard" role="listitem">
        <div class="passwordAccountInfo">
          <div class="passwordAccountMeta">
            <span class="passwordLabel"><%= t("user") %></span>
            <strong class="passwordAccountName"><%= account.username %></strong>
            <span class="passwordAccountUpdated"><%= account.updatedAt ? new Date(account.updatedAt).toLocaleString(localeTag || 'it-IT') : '' %></span>
          </div>

          <div class="passwordAccountMeta">
            <span class="passwordLabel"><%= t("role") %></span>
            <strong><%= account.role %></strong>
          </div>

          <% if (user && user.isMaster) { %>
            <div class="passwordAccountMeta">
              <span class="passwordLabel"><%= t("alliances") %></span>
              <strong><%= account.allianceId || '-' %></strong>
            </div>
          <% } %>
        </div>

        <form class="passwordInlineForm" method="post" action="/passwords/<%= account._id %>">
          <% if (!(user && user.isMaster)) { %>
            <label>
              <span><%= t("old_pin") %></span>
              <input type="password" name="oldPin" required minlength="6" maxlength="6" inputmode="numeric" pattern="\d{6}" autocomplete="current-password" />
            </label>
          <% } %>
          <label>
            <span><%= t("new_pin") %></span>
            <input type="password" name="newPin" required minlength="6" maxlength="6" inputmode="numeric" pattern="\d{6}" autocomplete="new-password" />
          </label>
          <label>
            <span><%= t("repeat_pin") %></span>
            <input type="password" name="confirmPin" required minlength="6" maxlength="6" inputmode="numeric" pattern="\d{6}" autocomplete="new-password" />
          </label>
          <button type="submit"><%= user && user.isMaster ? t('reset_pin') : t('change_pin') %></button>
        </form>
      </article>
    <% }) %>
  </div>
</section>

<%- include("../partials/footer") %>
