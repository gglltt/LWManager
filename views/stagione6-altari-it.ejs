  <nav class="seasonToc" aria-label="Indice guida Altari Stagione 6">
    <a href="#quando">Quando</a><a href="#regole">Regole</a><a href="#abilita">Abilità</a><a href="#strategia">Strategia</a><a href="#checklist">Checklist</a>
